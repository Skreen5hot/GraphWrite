m:height\": 120,\n          \"ecm:instanceIri\": \"urn:uuid:c3000000-0000-0000-0000-000000000003\",\n          \"ecm:width\": 220,\n          \"ecm:x\": 700,\n          \"ecm:y\": 100,\n          \"type\": \"ecm:CanvasNode\"\n        }\n      ],\n      \"id\": \"urn:uuid:c3000000-0000-0000-0000-000000000020\",\n      \"type\": \"ecm:CanvasLayout\"\n    }\n  ],\n  \"ecm:literalAssertions\": [],\n  \"ecm:name\": \"Canvas Fixture (3 instances, 2 relations, 2 ObjectProperties)\",\n  \"ecm:ontologies\": [],\n  \"ecm:relations\": [\n    {\n      \"ecm:objectIri\": \"urn:uuid:c3000000-0000-0000-0000-000000000002\",\n      \"ecm:predicateIri\": \"https://example.org/ontology/relatesTo\",\n      \"ecm:subjectIri\": \"urn:uuid:c3000000-0000-0000-0000-000000000001\",\n      \"id\": \"urn:uuid:c3000000-0000-0000-0000-000000000011\",\n      \"type\": \"ecm:RelationAssertion\"\n    },\n    {\n      \"ecm:objectIri\": \"urn:uuid:c3000000-0000-0000-0000-000000000003\",\n      \"ecm:predicateIri\": \"https://example.org/ontology/relatesTo\",\n      \"ecm:subjectIri\": \"urn:uuid:c3000000-0000-0000-0000-000000000002\",\n      \"id\": \"urn:uuid:c3000000-0000-0000-0000-000000000012\",\n      \"type\": \"ecm:RelationAssertion\"\n    }\n  ],\n  \"ecm:serializations\": [],\n  \"ecm:snapshots\": [],\n  \"ecm:terms\": [\n    {\n      \"ecm:createdAt\": \"2026-01-01T00:00:00Z\",\n      \"ecm:ontologyId\": null,\n      \"ecm:source\": \"ecm:project-created\",\n      \"ecm:updatedAt\": \"2026-01-01T00:00:00Z\",\n      \"id\": \"https://example.org/ontology/HasRole\",\n      \"rdfs:label\": \"Has Role\",\n      \"type\": \"owl:ObjectProperty\"\n    },\n    {\n      \"ecm:createdAt\": \"2026-01-01T00:00:00Z\",\n      \"ecm:ontologyId\": null,\n      \"ecm:source\": \"ecm:project-created\",\n      \"ecm:updatedAt\": \"2026-01-01T00:00:00Z\",\n      \"id\": \"https://example.org/ontology/relatesTo\",\n      \"rdfs:label\": \"Relates To\",\n      \"type\": \"owl:ObjectProperty\"\n    }\n  ],\n  \"ecm:updatedAt\": \"2026-01-01T00:00:00Z\",\n  \"iao:isAbout\": [\n    \"https://example.org/subjects/CanvasTest\"\n  ]\n}",
            "scope": "minimal"
          },
          {
            "id": "C5",
            "file": "tests/playwright/relation-crud.spec.ts",
            "rationale": "Insert CANVAS_FIXTURE_WITH_OPS path constant and CHAIN_B_REL_ID_1 / CHAIN_B_REL_ID_2 id constants after ORIGINAL_REL_IDS. The Chain B describe block (C6) references these. CHAIN_B_REL_ID_1 and CHAIN_B_REL_ID_2 are the same UUIDs as in ORIGINAL_REL_IDS \u00e2\u20ac\u201d extracted as named constants for test-intent clarity rather than relying on inline literals.",
            "before": "/** Relation ids already in the fixture (used to identify the newly created entry). */\nconst ORIGINAL_REL_IDS = new Set([\n  \"urn:uuid:c3000000-0000-0000-0000-000000000011\",\n  \"urn:uuid:c3000000-0000-0000-0000-000000000012\",\n]);\n\ntest.describe(\"Relation CRUD (task 2.6 Chain A)\", () => {",
            "after": "/** Relation ids already in the fixture (used to identify the newly created entry). */\nconst ORIGINAL_REL_IDS = new Set([\n  \"urn:uuid:c3000000-0000-0000-0000-000000000011\",\n  \"urn:uuid:c3000000-0000-0000-0000-000000000012\",\n]);\n\nconst CANVAS_FIXTURE_WITH_OPS = path.join(\n  process.cwd(),\n  \"tests\",\n  \"playwright\",\n  \"fixtures\",\n  \"canvas-3i-2r-with-ops.jsonld\",\n);\n\n/** First relation id used by Chain B predicate-select and reverse tests. */\nconst CHAIN_B_REL_ID_1 = \"urn:uuid:c3000000-0000-0000-0000-000000000011\";\n\n/** Second relation id used by Chain B delete test (the relation that survives). */\nconst CHAIN_B_REL_ID_2 = \"urn:uuid:c3000000-0000-0000-0000-000000000012\";\n\ntest.describe(\"Relation CRUD (task 2.6 Chain A)\", () => {",
            "scope": "minimal"
          },
          {
            "id": "C6",
            "file": "tests/playwright/relation-crud.spec.ts",
            "rationale": "Append the Chain B test.describe block with AC2 (predicate dropdown), AC3 (reverse), and AC4 (delete) tests. Edge-click strategy: bounding-box center via page.mouse.click, following the AC1 test's raw-mouse-events pattern (Event 8 lesson). This avoids the SVG hit-target ambiguity of calling .click() on an invisible <path strokeOpacity=0>. The react-flow__edge-interaction path exists in @xyflow/react v12 but has strokeOpacity:0, which Playwright may reject; using boundingBox ensures we click the centroid of the edge's rendered SVG group. AC2 selects 'Has Role' (a different IRI than the current 'relatesTo') and verifies the saved predicate. AC3 verifies Inspector immediately reflects the swap before saving. AC4 verifies Inspector returns to empty state (rel===undefined guard triggers naturally since selectedRelationId still points to the removed relation), edge count drops to 1, and saved file has exactly 1 relation.",
            "before": "      // The relation must not be a self-loop.\n      expect(\n        subjectIri,\n        \"ecm:subjectIri and ecm:objectIri must be distinct instances\",\n      ).not.toBe(objectIri);\n    },\n  );\n});",
            "after": "      // The relation must not be a self-loop.\n      expect(\n        subjectIri,\n        \"ecm:subjectIri and ecm:objectIri must be distinct instances\",\n      ).not.toBe(objectIri);\n    },\n  );\n});\n\ntest.describe(\"Relation CRUD (task 2.6 Chain B)\", () => {\n  test(\n    \"AC2: select predicate from dropdown; save; parse: ecm:predicateIri updated on relation\",\n    async ({ page }) => {\n      await page.goto(\"/\");\n      await page.getByTestId(\"gw-file-input\").setInputFiles(CANVAS_FIXTURE_WITH_OPS);\n      await expect(page.getByTestId(\"gw-btn-save\")).toBeEnabled();\n\n      const canvasView = page.getByTestId(\"gw-canvas-view\");\n      await expect(canvasView.locator(\".react-flow__node\")).toHaveCount(3, {\n        timeout: 10_000,\n      });\n      await expect(canvasView.locator(\".react-flow__edge\")).toHaveCount(2, {\n        timeout: 5_000,\n      });\n\n      // Click the first edge using bounding-box center (Event 8 lesson: raw\n      // mouse click avoids SVG hit-target ambiguity on invisible interaction path).\n      const firstEdge = canvasView.locator(\".react-flow__edge\").first();\n      const edgeBB = await firstEdge.boundingBox();\n      expect(edgeBB, \"first edge must have a bounding box\").not.toBeNull();\n      await page.mouse.click(\n        edgeBB!.x + edgeBB!.width / 2,\n        edgeBB!.y + edgeBB!.height / 2,\n      );\n\n      // Inspector must show the selected relation.\n      await expect(page.getByTestId(\"gw-inspector-relation\")).toBeVisible({\n        timeout: 5_000,\n      });\n\n      // Select \"Has Role\" -- a different predicate than the fixture's \"relatesTo\".\n      await page\n        .getByTestId(\"gw-select-predicate\")\n        .selectOption(\"https://example.org/ontology/HasRole\");\n\n      // Save and capture the download.\n      const [download] = await Promise.all([\n        page.waitForEvent(\"download\"),\n        page.getByTestId(\"gw-btn-save\").click(),\n      ]);\n\n      const downloadPath = await download.path();\n      expect(downloadPath, \"download must be saved to disk\").not.toBeNull();\n      const content = fs.readFileSync(downloadPath!, \"utf-8\");\n      const saved = JSON.parse(content) as Record<string, unknown>;\n\n      const relations = saved[\"ecm:relations\"] as Record<string, unknown>[];\n      expect(Array.isArray(relations)).toBe(true);\n\n      const rel = relations.find((r) => r[\"id\"] === CHAIN_B_REL_ID_1);\n      expect(rel, \"first relation must still exist\").toBeDefined();\n      expect(rel![\"ecm:predicateIri\"]).toBe(\n        \"https://example.org/ontology/HasRole\",\n      );\n    },\n  );\n\n  test(\n    \"AC3: Reverse button swaps ecm:subjectIri and ecm:objectIri\",\n    async ({ page }) => {\n      await page.goto(\"/\");\n      await page.getByTestId(\"gw-file-input\").setInputFiles(CANVAS_FIXTURE_WITH_OPS);\n      await expect(page.getByTestId(\"gw-btn-save\")).toBeEnabled();\n\n      const canvasView = page.getByTestId(\"gw-canvas-view\");\n      await expect(canvasView.locator(\".react-flow__node\")).toHaveCount(3, {\n        timeout: 10_000,\n      });\n      await expect(canvasView.locator(\".react-flow__edge\")).toHaveCount(2, {\n        timeout: 5_000,\n      });\n\n      // Known subject and object IRIs for the first fixture relation.\n      const originalSubject = \"urn:uuid:c3000000-0000-0000-0000-000000000001\";\n      const originalObject = \"urn:uuid:c3000000-0000-0000-0000-000000000002\";\n\n      // Click the first edge.\n      const firstEdge = canvasView.locator(\".react-flow__edge\").first();\n      const edgeBB = await firstEdge.boundingBox();\n      expect(edgeBB, \"first edge must have a bounding box\").not.toBeNull();\n      await page.mouse.click(\n        edgeBB!.x + edgeBB!.width / 2,\n        edgeBB!.y + edgeBB!.height / 2,\n      );\n\n      await expect(page.getByTestId(\"gw-inspector-relation\")).toBeVisible({\n        timeout: 5_000,\n      });\n      await expect(page.getByTestId(\"gw-inspector-subject\")).toHaveText(\n        originalSubject,\n      );\n      await expect(page.getByTestId(\"gw-inspector-object\")).toHaveText(\n        originalObject,\n      );\n\n      // Click Reverse.\n      await page.getByTestId(\"gw-btn-reverse\").click();\n\n      // Inspector must immediately reflect the swap.\n      await expect(page.getByTestId(\"gw-inspector-subject\")).toHaveText(\n        originalObject,\n      );\n      await expect(page.getByTestId(\"gw-inspector-object\")).toHaveText(\n        originalSubject,\n      );\n\n      // Save and verify in the parsed output.\n      const [download] = await Promise.all([\n        page.waitForEvent(\"download\"),\n        page.getByTestId(\"gw-btn-save\").click(),\n      ]);\n\n      const downloadPath = await download.path();\n      expect(downloadPath, \"download must be saved to disk\").not.toBeNull();\n      const content = fs.readFileSync(downloadPath!, \"utf-8\");\n      const saved = JSON.parse(content) as Record<string, unknown>;\n\n      const relations = saved[\"ecm:relations\"] as Record<string, unknown>[];\n      const rel = relations.find((r) => r[\"id\"] === CHAIN_B_REL_ID_1);\n      expect(rel, \"first relation must still exist after reverse\").toBeDefined();\n      expect(rel![\"ecm:subjectIri\"]).toBe(originalObject);\n      expect(rel![\"ecm:objectIri\"]).toBe(originalSubject);\n    },\n  );\n\n  test(\n    \"AC4: Delete button removes relation; Inspector returns to empty state; edge disappears from canvas\",\n    async ({ page }) => {\n      await page.goto(\"/\");\n      await page.getByTestId(\"gw-file-input\").setInputFiles(CANVAS_FIXTURE_WITH_OPS);\n      await expect(page.getByTestId(\"gw-btn-save\")).toBeEnabled();\n\n      const canvasView = page.getByTestId(\"gw-canvas-view\");\n      await expect(canvasView.locator(\".react-flow__node\")).toHaveCount(3, {\n        timeout: 10_000,\n      });\n      await expect(canvasView.locator(\".react-flow__edge\")).toHaveCount(2, {\n        timeout: 5_000,\n      });\n\n      // Click the first edge to select it.\n      const firstEdge = canvasView.locator(\".react-flow__edge\").first();\n      const edgeBB = await firstEdge.boundingBox();\n      expect(edgeBB, \"first edge must have a bounding box\").not.toBeNull();\n      await page.mouse.click(\n        edgeBB!.x + edgeBB!.width / 2,\n        edgeBB!.y + edgeBB!.height / 2,\n      );\n\n      await expect(page.getByTestId(\"gw-inspector-relation\")).toBeVisible({\n        timeout: 5_000,\n      });\n\n      // Click Delete.\n      await page.getByTestId(\"gw-btn-delete-relation\").click();\n\n      // Inspector must return to empty state (rel===undefined guard fires because\n      // selectedRelationId in App still points to the now-removed relation id).\n      await expect(page.getByTestId(\"gw-inspector-empty\")).toBeVisible({\n        timeout: 3_000,\n      });\n\n      // Canvas must now show one fewer edge.\n      await expect(canvasView.locator(\".react-flow__edge\")).toHaveCount(1, {\n        timeout: 5_000,\n      });\n\n      // Save and verify only the second relation remains.\n      const [download] = await Promise.all([\n        page.waitForEvent(\"download\"),\n        page.getByTestId(\"gw-btn-save\").click(),\n      ]);\n\n      const downloadPath = await download.path();\n      expect(downloadPath, \"download must be saved to disk\").not.toBeNull();\n      const content = fs.readFileSync(downloadPath!, \"utf-8\");\n      const saved = JSON.parse(content) as Record<string, unknown>;\n\n      const relations = saved[\"ecm:relations\"] as unknown[];\n      expect(Array.isArray(relations)).toBe(true);\n      expect(relations).toHaveLength(1);\n      expect(\n        (relations as Record<string, unknown>[])[0][\"id\"],\n      ).toBe(CHAIN_B_REL_ID_2);\n    },\n  );\n});",
            "scope": "moderate"
          }
        ],
        "tests_recommended": [
          {
            "file": "tests/playwright/relation-crud.spec.ts",
            "describe": "AC2/AC3/AC4 are the primary tests delivered in C6. Additional edge-case tests worth adding in a follow-up: (1) selecting ecm:UnassignedPredicate from the dropdown (round-trip back to unassigned state); (2) verify the predicate select is absent when no project is loaded (Inspector shows empty state placeholder); (3) reverse a relation whose subject/object are the same instance (self-loop edge case, though CanvasView's handleConnect guard may prevent self-loops from being created)."
          }
        ],
        "open_questions": [
          "Edge-click reliability (C6 tests): The tests click edges via page.mouse.click at the bounding-box center of .react-flow__edge (the <g> container). For nodes at the same y-coordinate (canvas-3i-2r-with-ops fixture layout has y=100 for all nodes), the edge is nearly horizontal and its centroid IS on the stroke. If the React Flow viewport applies fitView with a scale factor, the bounding box still returns screen coordinates so the math holds. Risk: if React Flow renders the edge path as a bezier curve that bows significantly away from the linear centroid, the click may land on empty space. Operator should smoke-test AC2/AC3/AC4 locally; if edge clicks fail, consider using `.react-flow__edge-interaction` with `{ force: true }` as fallback (the interaction path is present in @xyflow/react v12 per BaseEdge source inspection, just strokeOpacity:0).",
          "TypeScript ChangeEvent import: Inspector.tsx currently has zero imports. The <select> onChange handler infers its event type through JSX.IntrinsicElements from @types/react (no explicit React import needed with the automatic JSX transform). If the TypeScript build emits an error about the event type, adding `import { type ChangeEvent } from \"react\";` and annotating the handler `(e: ChangeEvent<HTMLSelectElement>)` resolves it without breaking purity.",
          "Predicate dropdown for predicates not in ecm:terms: If a relation's ecm:predicateIri is an IRI not present in ecm:terms (e.g., loaded from an older file where that term was deleted), no <option> will match the controlled value and the browser will render a blank or first-option selection. The current implementation does not add a 'current value' fallback option. This is acceptable for the current task scope but should be addressed in a follow-up if users observe stale IRIs disappearing from the select.",
          "Deduplication of EcmRelation interface (F14): Inspector.tsx and CanvasView.tsx each declare a local EcmRelation interface; they are structurally identical. The recon noted this is intentional per chain isolation. If a shared types file is introduced in a future task, both should be updated together."
        ],
        "summary": "Six targeted changes across three files implement FR-U015/U016/U017 + AC2/AC3/AC4. Inspector.tsx gains: (C1) iriTail + ObjPropOption + getObjectPropertyOptions helpers following the TermSidebar partitionTerms pattern; (C2) onProjectChange destructured from InspectorProps fixing the Chain A omission; (C3) handlePredicateChange / handleReverse / handleDelete function declarations (each with a null-guard matching TermSidebar style), a controlled <select> replacing the predicate <p> stub, and Reverse + Delete buttons replacing the stub comment. The new canvas-3i-2r-with-ops.jsonld fixture (C4) extends the Chain A fixture with two owl:ObjectProperty terms \u00e2\u20ac\u201d HasRole (new) and relatesTo (matching the existing relation predicates) \u00e2\u20ac\u201d enabling meaningful AC2 and AC3 verification. The spec file gains (C5) three new top-level constants and (C6) a Chain B test.describe block with full AC2/AC3/AC4 bodies using bounding-box-center mouse clicks for edge selection per the Event 8 lesson. App.tsx requires no changes: it already passes onProjectChange unconditionally (F2 finding).",
        "self_assessment": "confident"
      },
