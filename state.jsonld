            "before": "export function Inspector({\n  selectedRelationId,\n  project,\n}: InspectorProps) {",
            "after": "export function Inspector({\n  selectedRelationId,\n  project,\n  onProjectChange,\n}: InspectorProps) {",
            "scope": "minimal"
          },
          {
            "id": "C3",
            "file": "src/ui/Inspector.tsx",
            "rationale": "Replace the static predicate <p> stub (FR-U015 Chain B stub comment, F5) with a controlled <select> whose options are derived from ecm:terms owl:ObjectProperty entries. Add handlePredicateChange, handleReverse, handleDelete function declarations following TermSidebar's inline-function-declaration pattern. Each handler re-checks nullability (matching TermSidebar's handleAddConfirm pattern) to satisfy TypeScript's closure flow analysis. Replace the Reverse/Delete stub comment (F5) with the actual buttons. The predicate <select> retains a fixed ecm:UnassignedPredicate option so newly-drawn unassigned edges render sensibly. After delete, selectedRelationId in App remains set to the removed id; Inspector's own rel===undefined guard naturally returns the empty state \u00e2\u20ac\u201d no new prop needed.",
            "before": "  if (rel === undefined) {\n    return (\n      <p className=\"gw-placeholder\" data-testid=\"gw-inspector-empty\">\n        Select a relation to inspect.\n      </p>\n    );\n  }\n\n  return (\n    <div data-testid=\"gw-inspector-relation\">\n      <p style={{ fontWeight: 600, marginBottom: \"0.5rem\" }}>Relation</p>\n\n      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Subject\n      </p>\n      <p\n        style={{\n          fontSize: \"0.8rem\",\n          wordBreak: \"break-all\",\n          marginBottom: \"0.75rem\",\n        }}\n        data-testid=\"gw-inspector-subject\"\n      >\n        {rel[\"ecm:subjectIri\"]}\n      </p>\n\n      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Predicate\n      </p>\n      <p\n        style={{\n          fontSize: \"0.8rem\",\n          wordBreak: \"break-all\",\n          marginBottom: \"0.75rem\",\n          fontStyle:\n            rel[\"ecm:predicateIri\"] === \"ecm:UnassignedPredicate\"\n              ? \"italic\"\n              : \"normal\",\n        }}\n        data-testid=\"gw-inspector-predicate\"\n      >\n        {rel[\"ecm:predicateIri\"] === \"ecm:UnassignedPredicate\"\n          ? \"(unassigned -- select in Chain B)\"\n          : rel[\"ecm:predicateIri\"]}\n        {/* Chain B: replace with <select> of owl:ObjectProperty terms (FR-U015) */}\n      </p>\n\n      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Object\n      </p>\n      <p\n        style={{\n          fontSize: \"0.8rem\",\n          wordBreak: \"break-all\",\n          marginBottom: \"0.75rem\",\n        }}\n        data-testid=\"gw-inspector-object\"\n      >\n        {rel[\"ecm:objectIri\"]}\n      </p>\n\n      {/* Chain B: Reverse button (FR-U016) and Delete button (FR-U017) */}\n    </div>\n  );\n}",
            "after": "  if (rel === undefined) {\n    return (\n      <p className=\"gw-placeholder\" data-testid=\"gw-inspector-empty\">\n        Select a relation to inspect.\n      </p>\n    );\n  }\n\n  const objPropOptions = getObjectPropertyOptions(project);\n\n  function handlePredicateChange(newIri: string) {\n    if (onProjectChange === undefined || selectedRelationId === null || project === null) return;\n    const updatedRelations = rawRelations.map((r) => {\n      if (!isEcmRelation(r) || r.id !== selectedRelationId) return r;\n      return { ...(r as Record<string, unknown>), \"ecm:predicateIri\": newIri };\n    });\n    onProjectChange({ ...project, \"ecm:relations\": updatedRelations });\n  }\n\n  function handleReverse() {\n    if (onProjectChange === undefined || selectedRelationId === null || project === null) return;\n    const updatedRelations = rawRelations.map((r) => {\n      if (!isEcmRelation(r) || r.id !== selectedRelationId) return r;\n      return {\n        ...(r as Record<string, unknown>),\n        \"ecm:subjectIri\": r[\"ecm:objectIri\"],\n        \"ecm:objectIri\": r[\"ecm:subjectIri\"],\n      };\n    });\n    onProjectChange({ ...project, \"ecm:relations\": updatedRelations });\n  }\n\n  function handleDelete() {\n    if (onProjectChange === undefined || selectedRelationId === null || project === null) return;\n    const updatedRelations = rawRelations.filter(\n      (r) => !(isEcmRelation(r) && r.id === selectedRelationId),\n    );\n    onProjectChange({ ...project, \"ecm:relations\": updatedRelations });\n  }\n\n  return (\n    <div data-testid=\"gw-inspector-relation\">\n      <p style={{ fontWeight: 600, marginBottom: \"0.5rem\" }}>Relation</p>\n\n      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Subject\n      </p>\n      <p\n        style={{\n          fontSize: \"0.8rem\",\n          wordBreak: \"break-all\",\n          marginBottom: \"0.75rem\",\n        }}\n        data-testid=\"gw-inspector-subject\"\n      >\n        {rel[\"ecm:subjectIri\"]}\n      </p>\n\n      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Predicate\n      </p>\n      <select\n        value={rel[\"ecm:predicateIri\"]}\n        onChange={(e) => { handlePredicateChange(e.target.value); }}\n        data-testid=\"gw-select-predicate\"\n        style={{ fontSize: \"0.8rem\", marginBottom: \"0.75rem\", width: \"100%\" }}\n      >\n        <option value=\"ecm:UnassignedPredicate\">(unassigned)</option>\n        {objPropOptions.map((opt) => (\n          <option key={opt.iri} value={opt.iri}>\n            {opt.label}\n          </option>\n        ))}\n      </select>\n\n      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Object\n      </p>\n      <p\n        style={{\n          fontSize: \"0.8rem\",\n          wordBreak: \"break-all\",\n          marginBottom: \"0.75rem\",\n        }}\n        data-testid=\"gw-inspector-object\"\n      >\n        {rel[\"ecm:objectIri\"]}\n      </p>\n\n      <div style={{ display: \"flex\", gap: \"0.5rem\", marginTop: \"0.75rem\" }}>\n        <button\n          type=\"button\"\n          onClick={handleReverse}\n          data-testid=\"gw-btn-reverse\"\n          style={{ flex: 1 }}\n        >\n          Reverse\n        </button>\n        <button\n          type=\"button\"\n          onClick={handleDelete}\n          data-testid=\"gw-btn-delete-relation\"\n          style={{ flex: 1 }}\n        >\n          Delete\n        </button>\n      </div>\n    </div>\n  );\n}",
            "scope": "moderate"
          },
