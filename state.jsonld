      "outputs": {
        "changes": [
          {
            "id": "C1",
            "file": "src/ui/App.tsx",
            "rationale": "Add emitTurtle import required by handleSaveTurtle (FR-U023). Placed immediately after the serializeVmp import to group related serialization imports. Relative path ../emit/turtle.js matches the ESM .js convention already used throughout App.tsx imports.",
            "before": "import { serializeVmp } from \"../kernel/canonicalize.js\";",
            "after": "import { serializeVmp } from \"../kernel/canonicalize.js\";\nimport { emitTurtle } from \"../emit/turtle.js\";",
