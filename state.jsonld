            "kind": "observation"
          },
          {
            "id": "F19",
            "claim": "The `NORMALIZED_ON_SAVE` info finding must satisfy the SPEC \u00c2\u00a75.13 ValidationFinding schema: five required fields (`ecm:severity`, `ecm:code`, `ecm:message`, `ecm:target`, `ecm:acknowledged`), `type: \"ecm:ValidationFinding\"`, `ecm:acknowledged: false` by default, and `ecm:severity: \"ecm:info\"`; this is the same schema enforced in tests/structural-validator.test.ts AC-schema and tests/legacy-migration.test.ts AC2 schema checks.",
            "evidence": [
              {
                "file": "src/validate/index.ts",
                "lines": "90-103",
                "excerpt": "function makeInfo(\n  code: string,\n  message: string,\n  target: string,\n): ValidationFinding {\n  return {\n    type: \"ecm:ValidationFinding\",\n    \"ecm:severity\": \"ecm:info\",\n    \"ecm:code\": code,\n    \"ecm:message\": message,\n    \"ecm:target\": target,\n    \"ecm:acknowledged\": false,\n  };\n}"
              }
