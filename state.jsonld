      "@id": "urn:fnsr:task:210-recon-relation-crud",
      "agent": "reconnaissance",
      "status": "done",
      "attempts": 1,
      "outputs": {
        "findings": [
          {
            "id": "F1",
            "claim": "The right sidebar (Inspector) in App.tsx is a bare placeholder <p> element with no Inspector component built or imported.",
            "evidence": [
              {
                "file": "src/ui/App.tsx",
                "lines": "42-46",
                "excerpt": "* Right inspector: task 2.5+\n * Bottom outputs: task 2.10"
              },
              {
                "file": "src/ui/App.tsx",
                "lines": "225-227",
                "excerpt": "<aside className=\"gw-inspector\" data-testid=\"gw-inspector\">\n  <p className=\"gw-placeholder\">Inspector -- task 2.5</p>\n</aside>"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F2",
            "claim": "CanvasView.tsx hard-sets nodesConnectable={false} on the ReactFlow component, blocking the drag-to-create-edge gesture required for FR-U014.",
            "evidence": [
              {
                "file": "src/ui/CanvasView.tsx",
                "lines": "356-370",
                "excerpt": "<ReactFlow\n  nodes={nodes}\n  edges={edges}\n  nodesDraggable={onProjectChange !== undefined}\n  nodesConnectable={false}\n  elementsSelectable={false}\n  fitView={nodes.length > 0}\n  onPaneClick={handlePaneClick}\n  onNodeDragStop={handleNodeDragStop}\n>"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F3",
            "claim": "CanvasView.tsx hard-sets elementsSelectable={false} on the ReactFlow component, preventing all edge and node selection; edge selection is needed for the Inspector to track a selected relation.",
            "evidence": [
              {
                "file": "src/ui/CanvasView.tsx",
                "lines": "362",
                "excerpt": "elementsSelectable={false}"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F4",
            "claim": "No onConnect handler exists in CanvasView.tsx; the ReactFlow component has no onConnect, onEdgeClick, or onSelectionChange props wired.",
            "evidence": [
              {
                "file": "src/ui/CanvasView.tsx",
                "lines": "356-370",
                "excerpt": "<ReactFlow\n  nodes={nodes}\n  edges={edges}\n  nodesDraggable={...}\n  nodesConnectable={false}\n  elementsSelectable={false}\n  fitView={...}\n  onPaneClick={handlePaneClick}\n  onNodeDragStop={handleNodeDragStop}\n>"
              },
              {
                "file": "node_modules/@xyflow/react/dist/esm/types/component-props.d.ts",
                "lines": "69,164,190",
                "excerpt": "onEdgeClick?: (event: ReactMouseEvent, edge: EdgeType) => void;\n...\nonConnect?: OnConnect;\n...\nonSelectionChange?: OnSelectionChangeFunc<NodeType, EdgeType>;"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F5",
            "claim": "The @xyflow/react v12 onConnect API is: type OnConnect = (connection: Connection) => void, where Connection = { source: string; target: string; sourceHandle: string | null; targetHandle: string | null }.",
            "evidence": [
              {
                "file": "node_modules/@xyflow/system/dist/esm/types/general.d.ts",
                "lines": "64-73,104",
                "excerpt": "export type Connection = {\n  source: string;\n  target: string;\n  sourceHandle: string | null;\n  targetHandle: string | null;\n};\n...\nexport type OnConnect = (connection: Connection) => void;"
              },
              {
                "file": "package.json",
                "lines": "46",
                "excerpt": "\"@xyflow/react\": \"^12.0.0\""
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F6",
            "claim": "ecm:RelationAssertion schema (SPEC \u00c2\u00a75.9) requires id, type='ecm:RelationAssertion', ecm:subjectIri, ecm:predicateIri, and ecm:objectIri; all four fields are required with no optional default. The CanvasView TypeScript type guard isEcmRelation enforces the same four fields.",
            "evidence": [
              {
                "file": "project/SPEC.md",
                "lines": "487-504",
                "excerpt": "{\n  \"id\": \"urn:uuid:RELATION_UUID\",\n  \"type\": \"ecm:RelationAssertion\",\n  \"ecm:subjectIri\": \"urn:uuid:SUBJECT_UUID\",\n  \"ecm:predicateIri\": \"https://example.org/ontology/participatesIn\",\n  \"ecm:objectIri\": \"urn:uuid:OBJECT_UUID\",\n  ...\n}"
              },
              {
                "file": "src/ui/CanvasView.tsx",
                "lines": "72-82",
                "excerpt": "function isEcmRelation(v: unknown): v is EcmRelation {\n  ...\n  return (\n    typeof obj[\"id\"] === \"string\" &&\n    obj[\"type\"] === \"ecm:RelationAssertion\" &&\n    typeof obj[\"ecm:subjectIri\"] === \"string\" &&\n    typeof obj[\"ecm:objectIri\"] === \"string\" &&\n    typeof obj[\"ecm:predicateIri\"] === \"string\"\n  );\n}"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F7",
            "claim": "No ecm:UnassignedPredicate or equivalent placeholder symbol is defined in SPEC.md or the codebase; a relation created without ecm:predicateIri triggers the MALFORMED_RELATION hard error (\u00c2\u00a717.2).",
            "evidence": [
              {
                "file": "project/SPEC.md",
                "lines": "1249",
                "excerpt": "| `MALFORMED_RELATION` | A relation lacks `id`, `ecm:subjectIri`, `ecm:predicateIri`, or `ecm:objectIri`. |"
              },
              {
                "file": "project/SPEC.md",
                "lines": "581-587",
                "excerpt": "\"ecm:code\": \"MISSING_PREDICATE\",\n\"ecm:message\": \"Relation has no predicate IRI.\""
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F8",
            "claim": "The deriveEdges() function in CanvasView.tsx already maps ecm:relations to React Flow edges using rel.id as edge id, ecm:subjectIri as source, ecm:objectIri as target, and stores relationId + predicateIri in the data bag.",
            "evidence": [
              {
                "file": "src/ui/CanvasView.tsx",
                "lines": "156-172",
                "excerpt": "function deriveEdges(project: Record<string, unknown>): RelationEdge[] {\n  ...\n  return rawRelations.flatMap<RelationEdge>((rel) => {\n    if (!isEcmRelation(rel)) return [];\n    return [{\n      id: rel.id,\n      source: rel[\"ecm:subjectIri\"],\n      target: rel[\"ecm:objectIri\"],\n      data: { relationId: rel.id, predicateIri: rel[\"ecm:predicateIri\"] },\n    }];\n  });\n}"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F9",
            "claim": "Instance IRI generation in CanvasView.tsx uses crypto.randomUUID() inline (not src/iri/index.ts's generateIri()); the same urn:uuid: + UUIDv4 pattern is the established precedent for new entity IRIs in the UI layer.",
            "evidence": [
              {
                "file": "src/ui/CanvasView.tsx",
                "lines": "221",
                "excerpt": "const newIri = `urn:uuid:${crypto.randomUUID()}`;"
              },
              {
                "file": "src/iri/index.ts",
                "lines": "177-181",
                "excerpt": "case \"ecm:uuid-urn\": {\n  return `urn:uuid:${generateUuidV4()}`;\n}"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F10",
            "claim": "The existing canvas-3i-2r.jsonld fixture has ecm:terms:[] (no owl:ObjectProperty entries); it supports drawing-relation tests but cannot populate a predicate dropdown for FR-U015.",
            "evidence": [
              {
                "file": "tests/playwright/fixtures/canvas-3i-2r.jsonld",
                "lines": "169",
                "excerpt": "\"ecm:terms\": []"
              },
              {
                "file": "tests/playwright/fixtures/canvas-3i-2r.jsonld",
                "lines": "151-165",
                "excerpt": "\"ecm:relations\": [\n  { \"ecm:predicateIri\": \"https://example.org/ontology/relatesTo\", ... },\n  { \"ecm:predicateIri\": \"https://example.org/ontology/relatesTo\", ... }\n]"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F11",
            "claim": "The term-sidebar-2c-1op-1dp.jsonld fixture contains one owl:ObjectProperty (HasRole, ecm:imported-ontology source) but zero instances, so it alone cannot support a draw-then-select-predicate test.",
            "evidence": [
              {
                "file": "tests/playwright/fixtures/term-sidebar-2c-1op-1dp.jsonld",
                "lines": "92-98",
                "excerpt": "{\n  \"id\": \"https://example.org/ontology/HasRole\",\n  \"type\": \"owl:ObjectProperty\",\n  \"ecm:source\": \"ecm:imported-ontology\",\n  \"rdfs:label\": \"Has Role\"\n}"
              },
              {
                "file": "tests/playwright/fixtures/term-sidebar-2c-1op-1dp.jsonld",
                "lines": "72",
                "excerpt": "\"ecm:instances\": [],"
              }
            ],
            "kind": "observation"
          },
