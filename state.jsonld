      "@id": "urn:fnsr:task:185-recon-canvas",
      "agent": "reconnaissance",
      "status": "done",
      "attempts": 1,
      "outputs": {
        "findings": [
          {
            "id": "F1",
            "claim": "SPEC \u00c2\u00a715.3 names React Flow as the canvas library with custom node cards, directed edges, edge labels, drag/drop, zoom/pan, and serializable positions; it requires React Flow state to be derived from the canonical Editor Layer, not the reverse.",
            "evidence": [
              {
                "file": "project/SPEC.md",
                "lines": "1108-1111",
                "excerpt": "### 15.3 Canvas Library\n\nReact Flow. Custom node cards, directed edges, edge labels, drag/drop layout, zoom/pan, serializable node and edge positions. React Flow state must be derived from / synchronized with the canonical Editor Layer; React Flow internal state is not canonical."
              }
            ],
            "kind": "observation"
          },
