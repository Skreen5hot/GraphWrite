      "@id": "urn:fnsr:task:108-recon-emitter-typefix",
      "agent": "reconnaissance",
      "status": "done",
      "attempts": 1,
      "outputs": {
        "findings": [
          {
            "id": "F1",
            "claim": "`termForIri` at turtle.ts:55-57 has an inferred return type of `NamedNode<string> | BlankNode` because its ternary branches call `blankNode(iri.slice(2))` and `namedNode(expandIri(iri))` respectively; no explicit return-type annotation is present.",
            "evidence": [
              {
                "file": "src/emit/turtle.ts",
                "lines": "55-57",
                "excerpt": "function termForIri(iri: string) {\n  return iri.startsWith(\"_:\") ? blankNode(iri.slice(2)) : namedNode(expandIri(iri));\n}"
              },
              {
                "file": "src/emit/turtle.ts",
                "lines": "27",
                "excerpt": "const { namedNode, literal, quad: makeQuad, blankNode } = DataFactory;"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F2",
            "claim": "`Quad_Predicate` is defined as `NamedNode | Variable` in both `@types/n3` (line 76) and `@rdfjs/types/data-model.d.ts` (line 147); `BlankNode` is explicitly excluded from both definitions.",
            "evidence": [
              {
                "file": "node_modules/@types/n3/index.d.ts",
                "lines": "75-77",
                "excerpt": "export type Quad_Subject = NamedNode | BlankNode | Variable;\nexport type Quad_Predicate = NamedNode | Variable;\nexport type Quad_Object = NamedNode | Literal | BlankNode | Variable;"
              },
              {
                "file": "node_modules/@rdfjs/types/data-model.d.ts",
                "lines": "139-148",
                "excerpt": "export type Quad_Subject = NamedNode | BlankNode | Quad | Variable;\n...\nexport type Quad_Predicate = NamedNode | Variable;"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F3",
            "claim": "`DataFactoryInterface.quad` in `@types/n3` declares its `predicate` parameter as `RDF.Quad_Predicate` (i.e., `NamedNode | Variable`), not the wider n3-local `Term`; `BlankNode` cannot satisfy this constraint.",
            "evidence": [
              {
                "file": "node_modules/@types/n3/index.d.ts",
                "lines": "112-117",
                "excerpt": "quad(\n    subject: RDF.Quad_Subject,\n    predicate: RDF.Quad_Predicate,\n    object: RDF.Quad_Object,\n    graph?: RDF.Quad_Graph,\n): Quad;"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F4",
            "claim": "turtle.ts:131 passes `termForIri(p)` (type `NamedNode<string> | BlankNode`) in the predicate position of `makeQuad`, violating the `RDF.Quad_Predicate = NamedNode | Variable` constraint because `BlankNode` is not assignable to `NamedNode | Variable`.",
            "evidence": [
              {
                "file": "src/emit/turtle.ts",
                "lines": "126-133",
                "excerpt": "if (typeof s === \"string\" && typeof p === \"string\" && typeof o === \"string\") {\n  result.push(makeQuad(termForIri(s), termForIri(p), termForIri(o)));\n}"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F5",
            "claim": "turtle.ts:154 passes `termForIri(p)` (type `NamedNode<string> | BlankNode`) in the predicate position of the LiteralAssertion `makeQuad` call, violating the same `RDF.Quad_Predicate` constraint.",
            "evidence": [
              {
                "file": "src/emit/turtle.ts",
                "lines": "148-157",
                "excerpt": "if (\n  typeof s === \"string\" && typeof p === \"string\" &&\n  typeof v === \"string\" && typeof dt === \"string\"\n) {\n  result.push(makeQuad(\n    termForIri(s),\n    termForIri(p),\n    makeLiteralTerm(v, dt, typeof lang === \"string\" ? lang : null),\n  ));\n}"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F6",
            "claim": "All other predicate arguments in `nodeToQuads` (`rdfTypeNode`, `predNode`, `namedNode(expandIri(pred))`, `namedNode(expandIri(\"ecm:byteLength\"))`) are the result of direct `namedNode(...)` calls, which return `NamedNode<string>` \u00e2\u20ac\u201d a type satisfying `Quad_Predicate`. No additional predicate-position type violations exist beyond lines 131 and 154.",
            "evidence": [
              {
                "file": "src/emit/turtle.ts",
                "lines": "163-210",
                "excerpt": "const rdfTypeNode = namedNode(RDF_TYPE_IRI);\n...\nresult.push(makeQuad(subj, rdfTypeNode, termForIri(t)));\n...\nresult.push(makeQuad(subj, predNode, termForIri(v)));\n...\nresult.push(makeQuad(subj, namedNode(expandIri(pred)), literal(val)));\n...\nresult.push(makeQuad(subj, namedNode(expandIri(\"ecm:byteLength\")), ...));"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F7",
            "claim": "`ReturnType<typeof makeQuad>` resolves to `n3.BaseQuad` (not `n3.Quad`) because TypeScript's `ReturnType<>` utility applies the conditional type against the last call signature of an overloaded function, and the last overload of `DataFactoryInterface.quad` is generic (`Q_Out extends BaseQuad = Quad`), causing TypeScript to infer the constraint (`BaseQuad`) rather than the default (`Quad`).",
            "evidence": [
              {
                "file": "node_modules/@types/n3/index.d.ts",
                "lines": "118-123",
                "excerpt": "quad<Q_In extends RDF.BaseQuad = RDF.Quad, Q_Out extends BaseQuad = Quad>(\n    subject: Q_In[\"subject\"],\n    predicate: Q_In[\"predicate\"],\n    object: Q_In[\"object\"],\n    graph?: Q_In[\"graph\"],\n): Q_Out;"
              },
              {
                "file": "src/emit/turtle.ts",
                "lines": "121-122",
                "excerpt": "function nodeToQuads(node: Record<string, unknown>): ReturnType<typeof makeQuad>[] {\n  const result: ReturnType<typeof makeQuad>[] = [];"
              },
              {
                "file": "src/emit/turtle.ts",
                "lines": "230-231",
                "excerpt": "export function graphToQuads(graphNodes: unknown[]): ReturnType<typeof makeQuad>[] {\n  const quads: ReturnType<typeof makeQuad>[] = [];"
              }
            ],
            "kind": "inference"
          },
          {
            "id": "F8",
            "claim": "`n3.BaseQuad` is NOT structurally assignable to `RDF.Quad`: `n3.BaseQuad.subject` is typed `n3.Term = NamedNode | BlankNode | Literal | Variable | DefaultGraph`, which includes `Literal` and `DefaultGraph` not present in `RDF.Quad_Subject = NamedNode | BlankNode | Quad | Variable`; similarly `n3.BaseQuad.predicate: n3.Term` includes `BlankNode`/`Literal`/`DefaultGraph` not present in `RDF.Quad_Predicate = NamedNode | Variable`.",
            "evidence": [
              {
                "file": "node_modules/@types/n3/index.d.ts",
                "lines": "11",
                "excerpt": "export type Term = NamedNode | BlankNode | Literal | Variable | DefaultGraph;"
              },
              {
                "file": "node_modules/@types/n3/index.d.ts",
                "lines": "80-90",
                "excerpt": "export class BaseQuad implements RDF.BaseQuad {\n    constructor(subject: Term, predicate: Term, object: Term, graph?: Term);\n    ...\n    readonly subject: Term;\n    readonly predicate: Term;\n    readonly object: Term;\n    readonly graph: Term;\n}"
