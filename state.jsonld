          "project/SPEC.md",
          "project/IMPLEMENTATION_PLAN.md",
          "project/DECISIONS.md",
          "project/ROADMAP.md",
          "src/kernel/canonicalize.ts",
          "src/kernel/transform.ts",
          "src/kernel/index.ts",
          "src/tbox/index.ts",
          "tests/run-tests.ts",
          "tests/vmp-serializer.test.ts",
          "tests/tbox-bundle.test.ts",
          "package.json"
        ],
