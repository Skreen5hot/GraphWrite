            "trace": {
              "critic_missed_id": "M7"
            }
          },
          {
            "id": "I26",
            "title": "Sec 17.2 hard-errors table has no severity column; code -> severity binding is implicit only",
            "consensus": "critic_only",
            "resolution": "accept_critic",
