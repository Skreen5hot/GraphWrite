                "lines": "27-40",
                "excerpt": "async function findTestFiles(dir: string): Promise<string[]> {\n  const entries = await readdir(dir, { withFileTypes: true });\n  ...if (entry.isFile() && entry.name.endsWith(\".test.js\") && entry.name !== \"run-tests.js\") {"
              },
