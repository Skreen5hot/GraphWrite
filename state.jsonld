                "lines": "25-34",
                "excerpt": "export interface MigrationReport {\n  addedFields: string[];\n  removedFields: string[];\n  transformedFields: string[];\n  info: string[];\n}"
              },
              {
                "file": "src/migrate/index.ts",
                "lines": "264-289",
