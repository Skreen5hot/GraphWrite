    {
      "@id": "urn:fnsr:task:161-dev-react-shell-2",
      "agent": "developer",
      "status": "done",
      "attempts": 1,
      "outputs": {
        "changes": [
          {
            "id": "C1",
            "file": "src/ui/App.tsx",
            "rationale": "Replace the placeholder-comment shell with a fully wired component: useState for project document + migration banner text; useRef for the hidden file input; handleNew (FR-U001), handleOpen/handleFileChange (FR-U002), handleSave (FR-U003), and FR-U029 dismissible banner. Migration is inferred by reading ecm:specVersion before migrate() (for banner text) and by checking migrationReport arrays for non-emptiness (wasMigrated signal). validate() is called but its result is not displayed (FR-U028 is task 2.8). State variable named 'project' (not 'document') to avoid shadowing the browser global. document.null-check used as the MigrateResult discriminant because TypeScript narrows MigrateSuccess reliably via 'document === null' on the union.",
            "before": "import \"./App.css\";\n\n/**\n * GraphWrite App shell -- SPEC section 26 five-panel layout.\n *\n * Panels populated in subsequent tasks:\n *   Left sidebar (Term Manager): task 2.2\n *   Center canvas (Instance Canvas): task 2.4\n *   Right inspector: task 2.5+\n *   Bottom outputs: task 2.10\n * FR-U001 / FR-U002 / FR-U003 header controls: task 2.1 Chain 2.\n */\nexport function App() {\n  return (\n    <div className=\"gw-shell\">\n      <header className=\"gw-header\" data-testid=\"gw-header\">\n        <span className=\"gw-brand\">GraphWrite</span>\n        {/* New / Open / Save -- task 2.1 Chain 2 */}\n      </header>\n\n      <div className=\"gw-body\">\n        <aside className=\"gw-sidebar\" data-testid=\"gw-sidebar\">\n          <p className=\"gw-placeholder\">Term Manager -- task 2.2</p>\n        </aside>\n\n        <main className=\"gw-canvas\" data-testid=\"gw-canvas\">\n          <p className=\"gw-placeholder\">Instance Canvas -- task 2.4</p>\n        </main>\n\n        <aside className=\"gw-inspector\" data-testid=\"gw-inspector\">\n          <p className=\"gw-placeholder\">Inspector -- task 2.5</p>\n        </aside>\n      </div>\n\n      <section className=\"gw-outputs\" data-testid=\"gw-outputs\">\n        <p className=\"gw-placeholder\">Outputs -- task 2.10</p>\n      </section>\n    </div>\n  );\n}\n",
            "after": "import { useState, useRef, type ChangeEvent } from \"react\";\nimport \"./App.css\";\nimport { migrate } from \"../migrate/index.js\";\nimport { normalizeOnLoad } from \"../normalize/index.js\";\nimport { validate } from \"../validate/index.js\";\nimport { serializeVmp } from \"../kernel/canonicalize.js\";\n\n/**\n * Minimal v0.4 project document for FR-U001 New.\n * Per SPEC section 5 required fields + section 10.4 type/iao:isAbout shape.\n * ecm:_legacyAnchorPlaceholder is NOT set: validate() emits\n * MISSING_REALIST_ANCHOR (error); ecm:error display is FR-U028 scope (task 2.8).\n */\nfunction buildNewDocument(): Record<string, unknown> {\n  return {\n    id: \"urn:ecm:project:new\",\n    type: [\"ecm:Project\", \"iao:OntologyDesignPattern\"],\n    \"ecm:specVersion\": \"0.4\",\n    \"ecm:createdAt\": \"1970-01-01T00:00:00Z\",\n    \"ecm:instances\": [],\n    \"ecm:layouts\": [],\n    \"ecm:literalAssertions\": [],\n    \"ecm:name\": \"Untitled Project\",\n    \"ecm:ontologies\": [],\n    \"ecm:relations\": [],\n    \"ecm:serializations\": [],\n    \"ecm:snapshots\": [],\n    \"ecm:terms\": [],\n    \"ecm:updatedAt\": \"1970-01-01T00:00:00Z\",\n    \"iao:isAbout\": [\"ecm:UnspecifiedSubjectMatter\"],\n  };\n}\n\n/**\n * GraphWrite App shell -- SPEC section 26 five-panel layout.\n *\n * Panels populated in subsequent tasks:\n *   Left sidebar (Term Manager): task 2.2\n *   Center canvas (Instance Canvas): task 2.4\n *   Right inspector: task 2.5+\n *   Bottom outputs: task 2.10\n * FR-U001 / FR-U002 / FR-U003 / FR-U029 header controls: task 2.1 Chain 2.\n */\nexport function App() {\n  const [project, setProject] = useState<Record<string, unknown> | null>(null);\n  const [migrationBannerText, setMigrationBannerText] = useState<string | null>(null);\n  const fileInputRef = useRef<HTMLInputElement>(null);\n\n  // FR-U001: New project\n  function handleNew() {\n    setProject(buildNewDocument());\n    setMigrationBannerText(null);\n  }\n\n  // FR-U002: Open project -- trigger hidden file input\n  function handleOpen() {\n    fileInputRef.current?.click();\n  }\n\n  // FR-U002: File selected -- read, migrate, normalize, validate, set state\n  function handleFileChange(event: ChangeEvent<HTMLInputElement>) {\n    const file = event.target.files?.[0];\n    if (file === undefined) return;\n\n    const reader = new FileReader();\n    reader.onload = (loadEvent: ProgressEvent<FileReader>) => {\n      const raw = loadEvent.target?.result;\n      if (typeof raw !== \"string\") return;\n\n      let parsed: Record<string, unknown>;\n      try {\n        parsed = JSON.parse(raw) as Record<string, unknown>;\n      } catch {\n        // TODO (task 2.8): surface parse errors to user\n        return;\n      }\n\n      // Capture source version BEFORE migrate() for FR-U029 banner text.\n      const fromVersion =\n        typeof parsed[\"ecm:specVersion\"] === \"string\"\n          ? (parsed[\"ecm:specVersion\"] as string)\n          : null;\n\n      const migrateResult = migrate(parsed);\n      if (migrateResult.document === null) {\n        // TODO (task 2.8): surface migration refusal to user\n        return;\n      }\n\n      const { document: migrated, migrationReport } = migrateResult;\n\n      // Detect if migration actually occurred: any report arrays non-empty.\n      const wasMigrated =\n        migrationReport.addedFields.length > 0 ||\n        migrationReport.transformedFields.length > 0 ||\n        migrationReport.removedFields.length > 0 ||\n        migrationReport.info.length > 0;\n\n      const { document: normalized } = normalizeOnLoad(migrated);\n      // Call validate per FR-U002; findings display deferred to task 2.8.\n      void validate(normalized);\n\n      setProject(normalized);\n\n      if (wasMigrated) {\n        const from = fromVersion ?? \"unknown\";\n        setMigrationBannerText(`Project was migrated from v${from} to v0.4.`);\n      } else {\n        setMigrationBannerText(null);\n      }\n    };\n\n    reader.readAsText(file);\n    // Reset input so the same file can be re-opened in the same session.\n    event.target.value = \"\";\n  }\n\n  // FR-U003: Save project -- canonical serialize -> Blob -> browser download\n  function handleSave() {\n    if (project === null) return;\n    const text = serializeVmp(project);\n    const blob = new Blob([text], { type: \"application/ld+json\" });\n    const url = URL.createObjectURL(blob);\n    const anchor = document.createElement(\"a\");\n    anchor.href = url;\n    anchor.download = \"project.jsonld\";\n    anchor.click();\n    URL.revokeObjectURL(url);\n  }\n\n  return (\n    <div className=\"gw-shell\">\n      <header className=\"gw-header\" data-testid=\"gw-header\">\n        <span className=\"gw-brand\">GraphWrite</span>\n        <div className=\"gw-btn-group\">\n          <button\n            className=\"gw-btn\"\n            data-testid=\"gw-btn-new\"\n            onClick={handleNew}\n          >\n            New\n          </button>\n          <button\n            className=\"gw-btn\"\n            data-testid=\"gw-btn-open\"\n            onClick={handleOpen}\n          >\n            Open\n          </button>\n          <button\n            className=\"gw-btn\"\n            data-testid=\"gw-btn-save\"\n            onClick={handleSave}\n            disabled={project === null}\n          >\n            Save\n          </button>\n        </div>\n        <input\n          ref={fileInputRef}\n          type=\"file\"\n          accept=\".jsonld,.json\"\n          style={{ display: \"none\" }}\n          data-testid=\"gw-file-input\"\n          onChange={handleFileChange}\n        />\n        {migrationBannerText !== null && (\n          <div\n            className=\"gw-migration-banner\"\n            data-testid=\"gw-migration-banner\"\n          >\n            <span>{migrationBannerText}</span>\n            <button\n              className=\"gw-migration-dismiss\"\n              data-testid=\"gw-migration-dismiss\"\n              onClick={() => { setMigrationBannerText(null); }}\n              aria-label=\"Dismiss migration notice\"\n            >\n              &#x2715;\n            </button>\n          </div>\n        )}\n      </header>\n\n      <div className=\"gw-body\">\n        <aside className=\"gw-sidebar\" data-testid=\"gw-sidebar\">\n          <p className=\"gw-placeholder\">Term Manager -- task 2.2</p>\n        </aside>\n\n        <main className=\"gw-canvas\" data-testid=\"gw-canvas\">\n          <p className=\"gw-placeholder\">Instance Canvas -- task 2.4</p>\n        </main>\n\n        <aside className=\"gw-inspector\" data-testid=\"gw-inspector\">\n          <p className=\"gw-placeholder\">Inspector -- task 2.5</p>\n        </aside>\n      </div>\n\n      <section className=\"gw-outputs\" data-testid=\"gw-outputs\">\n        <p className=\"gw-placeholder\">Outputs -- task 2.10</p>\n      </section>\n    </div>\n  );\n}\n",
            "scope": "moderate"
          },
          {
            "id": "C2",
            "file": "src/ui/App.css",
            "rationale": "Append styles for the header button group (FR-U001/FR-U002/FR-U003) and the dismissible migration banner (FR-U029). Minimal addition; existing rules are untouched.",
            "before": ".gw-placeholder {\n  color: #94a3b8;\n  font-size: 0.875rem;\n  font-style: italic;\n}\n",
            "after": ".gw-placeholder {\n  color: #94a3b8;\n  font-size: 0.875rem;\n  font-style: italic;\n}\n\n/* -----------------------------------------------------------------------\n * Header button group (FR-U001 / FR-U002 / FR-U003)\n * --------------------------------------------------------------------- */\n\n.gw-btn-group {\n  display: flex;\n  gap: 0.5rem;\n}\n\n.gw-btn {\n  padding: 0.25rem 0.75rem;\n  border: 1px solid #475569;\n  border-radius: 4px;\n  background: #334155;\n  color: #f1f5f9;\n  font-size: 0.875rem;\n  cursor: pointer;\n}\n\n.gw-btn:hover:not(:disabled) {\n  background: #475569;\n}\n\n.gw-btn:disabled {\n  opacity: 0.4;\n  cursor: not-allowed;\n}\n\n/* -----------------------------------------------------------------------\n * Migration notice banner (FR-U029)\n * --------------------------------------------------------------------- */\n\n.gw-migration-banner {\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  margin-left: auto;\n  padding: 0.25rem 0.75rem;\n  background: #854d0e;\n  color: #fef9c3;\n  border-radius: 4px;\n  font-size: 0.8125rem;\n}\n\n.gw-migration-dismiss {\n  border: none;\n  background: transparent;\n  color: #fef9c3;\n  cursor: pointer;\n  font-size: 0.875rem;\n  padding: 0 0.25rem;\n  line-height: 1;\n}\n",
            "scope": "minimal"
          },
          {
            "id": "C3",
            "file": "tests/playwright/fixtures/minimal-v0.3.jsonld",
            "rationale": "Minimal v0.3 fixture for AC4 Playwright test. Has ecm:specVersion '0.3' so detectSourceVersion returns '0.3' and the v0.3->v0.4 migration leg fires. iao:isAbout is absent, so migrateV3toV4 adds it -> migrationReport.addedFields is non-empty -> wasMigrated=true -> FR-U029 banner appears. The ecm:settings block matches SETTINGS_DEFAULTS from src/migrate/index.ts (what a real v0.3 document carries after v0.2->v0.3 migration). Applier must create the tests/playwright/fixtures/ directory.",
            "before": null,
            "after": "{\n  \"id\": \"urn:uuid:00000000-0000-0000-0000-000000000020\",\n  \"type\": \"ecm:Project\",\n  \"ecm:specVersion\": \"0.3\",\n  \"ecm:name\": \"Minimal v0.3 Project\",\n  \"ecm:createdAt\": \"2026-01-01T00:00:00Z\",\n  \"ecm:updatedAt\": \"2026-01-01T00:00:00Z\",\n  \"ecm:terms\": [],\n  \"ecm:instances\": [],\n  \"ecm:relations\": [],\n  \"ecm:literalAssertions\": [],\n  \"ecm:ontologies\": [],\n  \"ecm:layouts\": [],\n  \"ecm:snapshots\": [],\n  \"ecm:serializations\": [],\n  \"ecm:settings\": {\n    \"type\": \"ecm:ProjectSettings\",\n    \"ecm:iriGeneration\": {\n      \"type\": \"ecm:IriGenerationPolicy\",\n      \"ecm:mode\": \"ecm:uuid-urn\",\n      \"ecm:baseIri\": \"https://example.org/instances/\",\n      \"ecm:pattern\": \"{baseIri}{classSlug}_{labelSlug}_{uuid}\",\n      \"ecm:separator\": \"_\",\n      \"ecm:caseStyle\": \"lower-kebab\",\n      \"ecm:includeClass\": true,\n      \"ecm:includeLabel\": true,\n      \"ecm:includeUuid\": true\n    },\n    \"ecm:export\": {\n      \"ecm:defaultRdfFormat\": \"text/turtle\",\n      \"ecm:includeProjectCreatedTerms\": true,\n      \"ecm:includeImportedOntologyContent\": false\n    },\n    \"ecm:determinism\": {\n      \"ecm:mode\": \"ecm:interactive\",\n      \"ecm:seed\": null\n    }\n  }\n}\n",
            "scope": "minimal"
          },
          {
            "id": "C4",
            "file": "tests/playwright/new-open-save.spec.ts",
            "rationale": "AC2/AC3/AC4 Playwright tests. Uses process.cwd() for fixture paths (safe in ESM Playwright context where __dirname is unavailable). AC2: clicks New then captures download and checks v0.4 shape fields. AC3: setInputFiles with v0.4 fixture, waits for Save to be enabled (async FileReader), captures download, compares string content to original fixture (assumes fixture has LF line endings matching serializeVmp output; no .gitattributes in repo -- see open_questions). AC4: setInputFiles with v0.3 fixture, awaits migration banner visibility (wasMigrated=true because iao:isAbout is added in v0.3->v0.4 leg), asserts banner text, clicks dismiss, asserts banner gone. 'download' destructuring uses [download] = await Promise.all([waitForEvent, click]) -- the recommended Playwright pattern for blob-URL downloads (supported since Playwright v1.25, present in v1.44).",
            "before": null,
            "after": "import { test, expect } from \"@playwright/test\";\nimport path from \"path\";\nimport fs from \"fs\";\n\n/**\n * Task 2.1 Chain 2 -- AC2 / AC3 / AC4.\n *\n * AC2: New -> Save -> re-parse: downloaded file has ecm:specVersion \"0.4\",\n *      correct type array, and iao:isAbout array.\n * AC3: Open v0.4 fixture -> Save -> re-parse: bytewise identical to the\n *      original fixture (assumes fixture has LF line endings; see SPEC\n *      section 5.3 rule 7 -- serializeVmp always emits LF).\n * AC4: Open v0.3 fixture -> migration banner visible before any user\n *      action; banner text includes version; banner dismissible.\n *\n * AC1 + AC5 live in tests/playwright/shell.spec.ts (Chain 1).\n */\n\n// Resolve fixture paths from the project root (process.cwd()).\n// Playwright is invoked from the project root via 'npm run test:e2e'.\nconst V04_FIXTURE = path.join(\n  process.cwd(),\n  \"test\",\n  \"fixtures\",\n  \"canonical-v0.4\",\n  \"minimal.jsonld\",\n);\nconst V03_FIXTURE = path.join(\n  process.cwd(),\n  \"tests\",\n  \"playwright\",\n  \"fixtures\",\n  \"minimal-v0.3.jsonld\",\n);\n\ntest.describe(\"GraphWrite shell (task 2.1 AC2 + AC3 + AC4)\", () => {\n  test(\"AC2: New -> Save -> re-parse has correct v0.4 fields\", async ({\n    page,\n  }) => {\n    await page.goto(\"/\");\n\n    // FR-U001: create a fresh document\n    await page.getByTestId(\"gw-btn-new\").click();\n\n    // Wait for React state update -- Save becomes enabled once project != null\n    await expect(page.getByTestId(\"gw-btn-save\")).toBeEnabled();\n\n    // FR-U003: save and capture the download\n    const [download] = await Promise.all([\n      page.waitForEvent(\"download\"),\n      page.getByTestId(\"gw-btn-save\").click(),\n    ]);\n\n    const downloadPath = await download.path();\n    expect(downloadPath, \"download must be saved to disk\").not.toBeNull();\n\n    const content = fs.readFileSync(downloadPath!, \"utf-8\");\n    const parsed = JSON.parse(content) as Record<string, unknown>;\n\n    expect(parsed[\"ecm:specVersion\"]).toBe(\"0.4\");\n    expect(Array.isArray(parsed[\"type\"]), \"type must be an array\").toBe(true);\n    expect(parsed[\"type\"]).toContain(\"ecm:Project\");\n    expect(parsed[\"type\"]).toContain(\"iao:OntologyDesignPattern\");\n    expect(\n      Array.isArray(parsed[\"iao:isAbout\"]),\n      \"iao:isAbout must be an array\",\n    ).toBe(true);\n    expect(\n      (parsed[\"iao:isAbout\"] as string[]).length,\n      \"iao:isAbout must be non-empty\",\n    ).toBeGreaterThan(0);\n  });\n\n  test(\n    \"AC3: Open v0.4 fixture -> Save -> downloaded content bytewise identical to fixture\",\n    async ({ page }) => {\n      await page.goto(\"/\");\n\n      // FR-U002: load v0.4 fixture via hidden file input (no OS dialog)\n      await page.getByTestId(\"gw-file-input\").setInputFiles(V04_FIXTURE);\n\n      // Wait for async FileReader + React state update\n      await expect(page.getByTestId(\"gw-btn-save\")).toBeEnabled();\n\n      // FR-U003: save and capture\n      const [download] = await Promise.all([\n        page.waitForEvent(\"download\"),\n        page.getByTestId(\"gw-btn-save\").click(),\n      ]);\n\n      const downloadPath = await download.path();\n      expect(downloadPath, \"download must be saved to disk\").not.toBeNull();\n\n      const downloaded = fs.readFileSync(downloadPath!, \"utf-8\");\n      const original = fs.readFileSync(V04_FIXTURE, \"utf-8\");\n\n      expect(\n        downloaded,\n        \"saved content must be bytewise identical to the v0.4 fixture\",\n      ).toBe(original);\n    },\n  );\n\n  test(\n    \"AC4: Open v0.3 fixture -> migration banner visible; banner dismissible\",\n    async ({ page }) => {\n      await page.goto(\"/\");\n\n      // FR-U002: load v0.3 fixture via hidden file input\n      await page.getByTestId(\"gw-file-input\").setInputFiles(V03_FIXTURE);\n\n      // FR-U029: migration banner must appear before any additional user action\n      const banner = page.getByTestId(\"gw-migration-banner\");\n      await expect(banner).toBeVisible();\n\n      // Banner text must name source and target versions\n      await expect(banner).toContainText(\"migrated from v0.3 to v0.4\");\n\n      // Dismiss removes the banner from the DOM\n      await page.getByTestId(\"gw-migration-dismiss\").click();\n      await expect(banner).not.toBeVisible();\n    },\n  );\n});\n",
            "scope": "minimal"
          }
        ],
        "tests_recommended": [
          {
            "file": "tests/playwright/new-open-save.spec.ts",
            "describe": "AC2 (New->Save), AC3 (Open v0.4->Save roundtrip), AC4 (Open v0.3 migration banner) -- delivered as C4 above; run via 'npm run build:ui && npm run test:e2e' after applying all four changes."
