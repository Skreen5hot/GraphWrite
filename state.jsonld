      "outputs": {
        "findings": [
          {
            "id": "F1",
            "claim": "Dialog.tsx exports a reusable `Dialog` component accepting four props: `title: string`, `onClose: () => void`, `children: ReactNode`, and optional `testId?: string` (defaults to `\"gw-dialog\"`); it wraps the native HTML `<dialog>` element with `showModal()` on mount, Escape-to-close via the browser's native `close` event, and an explicit close button.",
            "evidence": [
              {
                "file": "src/ui/Dialog.tsx",
                "lines": "15-21",
                "excerpt": "interface DialogProps {\n  title: string;\n  onClose: () => void;\n  children: ReactNode;\n  /** data-testid on the <dialog> element. Defaults to \"gw-dialog\". */\n  testId?: string;\n}"
              },
              {
                "file": "src/ui/Dialog.tsx",
                "lines": "50-66",
                "excerpt": "<dialog ref={ref} className=\"gw-dialog\" data-testid={testId}>\n  <div className=\"gw-dialog-header\">\n    <h2 className=\"gw-dialog-title\">{title}</h2>\n    <button type=\"button\" className=\"gw-dialog-close\" onClick={onClose} aria-label=\"Close dialog\">&#x2715;</button>\n  </div>\n  <div className=\"gw-dialog-body\">{children}</div>\n</dialog>"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F2",
            "claim": "AddTermDialog.tsx accepts `termType: AddTermType`, `project: Record<string, unknown>` (read-only), `onConfirm: (newTerm: Record<string, unknown>) => void`, and `onClose: () => void`; it builds a SPEC \u00c2\u00a75.7-shaped term object with `ecm:source: \"ecm:project-created\"`, `rdfs:label`, `id` (IRI), timestamps, and `type`, but does NOT include a `rdfs:comment` field.",
            "evidence": [
              {
                "file": "src/ui/AddTermDialog.tsx",
                "lines": "21-28",
                "excerpt": "interface AddTermDialogProps {\n  termType: AddTermType;\n  /** Read-only; used for IRI uniqueness check. */\n  project: Record<string, unknown>;\n  /** Called with the new SPEC \u00c2\u00a75.7-shaped term entry on successful submit. */\n  onConfirm: (newTerm: Record<string, unknown>) => void;\n  onClose: () => void;\n}"
              },
              {
                "file": "src/ui/AddTermDialog.tsx",
                "lines": "81-91",
                "excerpt": "const newTerm: Record<string, unknown> = {\n  \"ecm:createdAt\": now,\n  \"ecm:ontologyId\": null,\n  \"ecm:source\": \"ecm:project-created\",\n  \"ecm:updatedAt\": now,\n  id: iri,\n  \"rdfs:label\": trimmedLabel,\n  type: termType,\n};"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F3",
            "claim": "AddTermDialog renders two input fields (Label and IRI override) plus Cancel/Submit buttons as children of `Dialog`; EditTermDialog would need the same two fields plus a `rdfs:comment` textarea for FR-U009 and would differ in submit button label and initial state (pre-populated from existing term data).",
            "evidence": [
              {
                "file": "src/ui/AddTermDialog.tsx",
