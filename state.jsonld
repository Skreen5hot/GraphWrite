            "id": "F1",
            "claim": "The Turtle emitter's public API is a single function `emitTurtle(project: Record<string, unknown>): string` that accepts a project document directly and performs the projection internally.",
            "evidence": [
              {
                "file": "src/emit/turtle.ts",
                "lines": "250-263",
                "excerpt": "export function emitTurtle(project: Record<string, unknown>): string {\n  const semanticDoc = JSON.parse(projectSemantic(project)) as Record<string, unknown>;\n  const graphArr: unknown[] = Array.isArray(semanticDoc[\"@graph\"])\n    ? (semanticDoc[\"@graph\"] as unknown[])\n    : [];\n  const quads = graphToQuads(graphArr);\n  let body = \"\";\n  const writer = new Writer();\n  writer.addQuads(quads);\n  writer.end((_err, r) => { body = r; });\n  return getProjectTBoxTurtle() + body;\n}"
              },
              {
                "file": "src/emit/turtle.ts",
                "lines": "8-9",
