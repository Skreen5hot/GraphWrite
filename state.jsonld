      ],
      "inputs": {
        "task_context": "Phase 2 task 2.4 Chain A: React Flow canvas + ecm:instances/ecm:relations binding",
        "output_envelope_constraint": "Output wrapped: outputs.changes[] (mode=create or edit), outputs.summary, outputs.self_assessment.",
        "goal": "Propose changes[] implementing Phase 2 task 2.4 Chain A. Minimum scope: React Flow canvas in center panel, bound to ecm:instances + ecm:relations as derived view of project document; AC1 Playwright test.",
        "implementation_directions": [
