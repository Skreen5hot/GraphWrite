            "claim": "No `tests/normalize-on-load.test.ts` file currently exists in the tests directory.",
            "evidence": [
              {
                "file": "tests",
                "lines": "N/A",
                "excerpt": "Glob `tests/**/*.ts` returns: determinism.test.ts, no-network.test.ts, run-tests.ts, snapshot.test.ts, vmp-serializer.test.ts, tbox-bundle.test.ts, structural-validator.test.ts, semantic-projection.test.ts, emitters.test.ts, iri-generation.test.ts, iri-refactor.test.ts, manifest-entries.test.ts, legacy-migration.test.ts \u00e2\u20ac\u201d no normalize-on-load.test.ts present."
              }
