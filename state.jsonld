      "outputs": {
        "changes": [
          {
            "id": "C1",
            "file": "src/ui/Inspector.tsx",
            "rationale": "Add import for narrateTriple from src/emit/triple-narration.js. App.tsx already imports from src/emit (recon F11), establishing the UI-to-emit pattern. narrateTriple is called via the resolveRelationNarration helper added in C2; importing the existing helper satisfies the scope constraint to reuse rather than reimplement.",
            "before": "import { useState } from \"react\";\nimport { AddLiteralDialog } from \"./AddLiteralDialog.js\";",
            "after": "import { useState } from \"react\";\nimport { AddLiteralDialog } from \"./AddLiteralDialog.js\";\nimport { narrateTriple } from \"../emit/triple-narration.js\";",
            "scope": "minimal"
          },
          {
            "id": "C2",
            "file": "src/ui/Inspector.tsx",
            "rationale": "Add resolveRelationNarration() helper between iriTail and getObjectPropertyOptions. Mirrors label-resolution logic from narrateProject() (triple-narration.ts lines 67-122) but scoped to a single EcmRelation so Inspector can call narrateTriple() directly. narrateProject() returns a flat string[] with no per-relation ID (recon F2) making it unsuitable for single-relation lookup. Label-resolution order matches the existing module: subjectLabel/objectLabel = instance rdfs:label ?? id; className/objectClassName = termLabel for first classIri ?? classIri ?? ''; predicateLabel = termLabel for predicateIri ?? predicateIri.",
            "before": "/** Extract the IRI tail (fragment after last '#' or last path segment). */\nfunction iriTail(iri: string): string {\n  const hash = iri.lastIndexOf(\"#\");\n  const slash = iri.lastIndexOf(\"/\");\n  const idx = Math.max(hash, slash);\n  return idx >= 0 ? iri.slice(idx + 1) : iri;\n}\n\n/** Shape of an owl:ObjectProperty option for the predicate <select>. */",
            "after": "/** Extract the IRI tail (fragment after last '#' or last path segment). */\nfunction iriTail(iri: string): string {\n  const hash = iri.lastIndexOf(\"#\");\n  const slash = iri.lastIndexOf(\"/\");\n  const idx = Math.max(hash, slash);\n  return idx >= 0 ? iri.slice(idx + 1) : iri;\n}\n\n/**\n * Resolve the FR-C008 narration for a single selected relation (FR-U020).\n * Label-resolution mirrors narrateProject() in triple-narration.ts but scoped\n * to one EcmRelation (narrateProject returns no per-relation ID -- recon F2).\n */\nfunction resolveRelationNarration(\n  rel: EcmRelation,\n  project: Record<string, unknown>,\n): string {\n  const instanceLabel = new Map<string, string>();\n  const instanceClass = new Map<string, string>();\n  const termLabel = new Map<string, string>();\n\n  const instances = project[\"ecm:instances\"];\n  if (Array.isArray(instances)) {\n    for (const item of instances as unknown[]) {\n      if (!item || typeof item !== \"object\") continue;\n      const inst = item as Record<string, unknown>;\n      const id = inst[\"id\"];\n      if (typeof id !== \"string\") continue;\n      instanceLabel.set(id, typeof inst[\"rdfs:label\"] === \"string\" ? inst[\"rdfs:label\"] : id);\n      const classIris = inst[\"ecm:classIris\"];\n      if (Array.isArray(classIris) && classIris.length > 0 && typeof classIris[0] === \"string\") {\n        instanceClass.set(id, String(classIris[0]));\n      }\n    }\n  }\n\n  const terms = project[\"ecm:terms\"];\n  if (Array.isArray(terms)) {\n    for (const item of terms as unknown[]) {\n      if (!item || typeof item !== \"object\") continue;\n      const term = item as Record<string, unknown>;\n      const id = term[\"id\"];\n      if (typeof id !== \"string\") continue;\n      termLabel.set(id, typeof term[\"rdfs:label\"] === \"string\" ? term[\"rdfs:label\"] : id);\n    }\n  }\n\n  const sIri = rel[\"ecm:subjectIri\"];\n  const pIri = rel[\"ecm:predicateIri\"];\n  const oIri = rel[\"ecm:objectIri\"];\n\n  const subjectLabel    = instanceLabel.get(sIri) ?? sIri;\n  const objectLabel     = instanceLabel.get(oIri) ?? oIri;\n  const subClassRaw     = instanceClass.get(sIri) ?? \"\";\n  const className       = subClassRaw !== \"\" ? (termLabel.get(subClassRaw) ?? subClassRaw) : \"\";\n  const objClassRaw     = instanceClass.get(oIri) ?? \"\";\n  const objectClassName = objClassRaw !== \"\" ? (termLabel.get(objClassRaw) ?? objClassRaw) : \"\";\n  const predicateLabel  = termLabel.get(pIri) ?? pIri;\n\n  return narrateTriple({ subjectLabel, className, predicateLabel, objectLabel, objectClassName });\n}\n\n/** Shape of an owl:ObjectProperty option for the predicate <select>. */",
            "scope": "minimal"
          },
          {
            "id": "C3",
            "file": "src/ui/Inspector.tsx",
            "rationale": "Insert Preview section into relation-mode JSX between the Object display and the action-button row. Adds gw-triple-narration (FR-C008 narration via resolveRelationNarration) and gw-triple-iri (angle-bracket IRI triple per IMPLEMENTATION_PLAN task 2.8 AC2). Existing gw-inspector-subject and gw-inspector-object elements are NOT modified, preserving the raw-IRI text asserted by existing relation-crud.spec.ts AC3 (recon F9). The IRI triple uses a template literal inside a JSX expression; angle brackets are literal string characters, not JSX tags.",
            "before": "      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Object\n      </p>\n      <p\n        style={{\n          fontSize: \"0.8rem\",\n          wordBreak: \"break-all\",\n          marginBottom: \"0.75rem\",\n        }}\n        data-testid=\"gw-inspector-object\"\n      >\n        {rel[\"ecm:objectIri\"]}\n      </p>\n\n      <div style={{ display: \"flex\", gap: \"0.5rem\", marginTop: \"0.75rem\" }}>\n        <button\n          type=\"button\"\n          onClick={handleReverse}\n          data-testid=\"gw-btn-reverse\"\n          style={{ flex: 1 }}\n        >\n          Reverse\n        </button>\n        <button\n          type=\"button\"\n          onClick={handleDelete}\n          data-testid=\"gw-btn-delete-relation\"\n          style={{ flex: 1 }}\n        >\n          Delete\n        </button>\n      </div>\n    </div>\n  );\n}",
            "after": "      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Object\n      </p>\n      <p\n        style={{\n          fontSize: \"0.8rem\",\n          wordBreak: \"break-all\",\n          marginBottom: \"0.75rem\",\n        }}\n        data-testid=\"gw-inspector-object\"\n      >\n        {rel[\"ecm:objectIri\"]}\n      </p>\n\n      <p style={{ fontWeight: 600, marginBottom: \"0.5rem\", marginTop: \"0.75rem\" }}>\n        Preview\n      </p>\n      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Plain language (FR-C008)\n      </p>\n      <p\n        style={{ fontSize: \"0.8rem\", wordBreak: \"break-all\", marginBottom: \"0.75rem\" }}\n        data-testid=\"gw-triple-narration\"\n      >\n        {resolveRelationNarration(rel, project)}\n      </p>\n      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        IRI triple\n      </p>\n      <p\n        style={{ fontSize: \"0.8rem\", wordBreak: \"break-all\", fontFamily: \"monospace\", marginBottom: \"0.75rem\" }}\n        data-testid=\"gw-triple-iri\"\n      >\n        {`<${rel[\"ecm:subjectIri\"]}> <${rel[\"ecm:predicateIri\"]}> <${rel[\"ecm:objectIri\"]}> .`}\n      </p>\n\n      <div style={{ display: \"flex\", gap: \"0.5rem\", marginTop: \"0.75rem\" }}>\n        <button\n          type=\"button\"\n          onClick={handleReverse}\n          data-testid=\"gw-btn-reverse\"\n          style={{ flex: 1 }}\n        >\n          Reverse\n        </button>\n        <button\n          type=\"button\"\n          onClick={handleDelete}\n          data-testid=\"gw-btn-delete-relation\"\n          style={{ flex: 1 }}\n        >\n          Delete\n        </button>\n      </div>\n    </div>\n  );\n}",
