        "findings": [
          {
            "id": "F1",
            "claim": "The IRI generation helper `generateIri(policy, context)` is implemented in `src/iri/index.ts` and produces `urn:uuid:<UUID>` strings in two modes: `ecm:uuid-urn` (UUIDv4, non-deterministic) and `ecm:deterministic` (UUIDv5 from `${seed}|${entityContext}`).",
            "evidence": [
              {
                "file": "src/iri/index.ts",
                "lines": "177-205",
                "excerpt": "export function generateIri(policy: IriPolicy, context: IriContext): string { switch (policy) { case \"ecm:uuid-urn\": { return `urn:uuid:${generateUuidV4()}`; } case \"ecm:deterministic\": { ... return `urn:uuid:${generateUuidV5(`${seed}|${entityContext}`)}`; } } }"
              }
            ],
            "kind": "observation"
          },
