            "before": "import {\n  ReactFlow,\n  ReactFlowProvider,\n  Background,\n  Controls,\n  useReactFlow,\n  type Node,\n  type Edge,\n} from \"@xyflow/react\";",
            "after": "import {\n  ReactFlow,\n  ReactFlowProvider,\n  Background,\n  Controls,\n  useReactFlow,\n  type Node,\n  type Edge,\n  type Connection,\n} from \"@xyflow/react\";",
