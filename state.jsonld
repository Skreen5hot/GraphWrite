          },
          {
            "id": "F7",
            "claim": "`src/cli/index.ts` demonstrates the adapter-tier pattern (imports from kernel/migrate/validate/emit; does not import from adapters/ or composition/). This is the only existing adapter-tier entry point; no `src/ui/` directory, no `index.html`, and no Vite configuration exist anywhere in the current file tree.",
            "evidence": [
              {
                "file": "src/cli/index.ts",
                "lines": "1-33",
                "excerpt": "import { parseArgs } from \"node:util\";\n...\nimport { stableStringify } from \"../kernel/canonicalize.js\";\nimport { validate } from \"../validate/index.js\";\nimport { migrate } from \"../migrate/index.js\";\nimport { emitTurtle } from \"../emit/turtle.js\";"
              }
            ],
