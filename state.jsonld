            "file": "tests/cli-integration.test.ts",
            "describe": "Already included in C4. Chain 2 follow-up should add: refactor-iri round-trip (--old/--new flags, exit 0 output contains newIri); export --format n-triples (structural: output contains '<'); export --format markdown (structural: output starts with '# '); export --out <file> writes file to disk and exits 0; --allow-outside-cwd permits a path outside CWD."
