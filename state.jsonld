    {
      "@id": "urn:fnsr:task:166-dev-term-sidebar",
      "agent": "developer",
      "status": "done",
      "attempts": 1,
      "outputs": {
        "changes": [
          {
            "id": "C1",
            "file": "src/ui/TermSidebar.tsx",
            "rationale": "New component per task 2.2. Placed as a sibling of App.tsx (no src/ui/components/ subdirectory exists per F3/F4). Partitions ecm:terms by type, renders three fixed sections with empty-state text, and emits source-indicator badges with both CSS class and aria-label per AC2. IRI-tail fallback matches triple-narration.ts precedent (F13). Return types are inferred, matching App.tsx style.",
            "before": null,
            "after": "/**\n * TermSidebar -- task 2.2 Term Manager left sidebar.\n *\n * Renders three sections (Classes, Object Properties, Datatype Properties)\n * from the canonical project document's ecm:terms array.\n * Source-indicator badges carry both CSS class + aria-label per AC2.\n * SPEC \u00a75.7 / FR-U004 / FR-U005.\n */\n\n/** Shape of a single ecm:terms entry (SPEC \u00a75.7). */\ninterface TermEntry {\n  id: string;\n  type: string;\n  \"rdfs:label\"?: string;\n  \"ecm:source\"?: string;\n}\n\ninterface TermSidebarProps {\n  project: Record<string, unknown> | null;\n}\n\n/** Extract the IRI tail (fragment after last '#' or last path segment). */\nfunction iriTail(iri: string): string {\n  const hash = iri.lastIndexOf(\"#\");\n  const slash = iri.lastIndexOf(\"/\");\n  const idx = Math.max(hash, slash);\n  return idx >= 0 ? iri.slice(idx + 1) : iri;\n}\n\n/** Coerce an ecm:terms array element to TermEntry; returns null if malformed. */\nfunction toTermEntry(item: unknown): TermEntry | null {\n  if (typeof item !== \"object\" || item === null) return null;\n  const obj = item as Record<string, unknown>;\n  if (typeof obj[\"id\"] !== \"string\") return null;\n  return obj as unknown as TermEntry;\n}\n\n/** Partition the project's ecm:terms into typed buckets. */\nfunction partitionTerms(project: Record<string, unknown> | null): {\n  classes: TermEntry[];\n  objectProperties: TermEntry[];\n  datatypeProperties: TermEntry[];\n} {\n  if (project === null) {\n    return { classes: [], objectProperties: [], datatypeProperties: [] };\n  }\n  const raw = project[\"ecm:terms\"];\n  if (!Array.isArray(raw)) {\n    return { classes: [], objectProperties: [], datatypeProperties: [] };\n  }\n  const terms = (raw as unknown[])\n    .map(toTermEntry)\n    .filter((t): t is TermEntry => t !== null);\n  return {\n    classes: terms.filter((t) => t.type === \"owl:Class\"),\n    objectProperties: terms.filter((t) => t.type === \"owl:ObjectProperty\"),\n    datatypeProperties: terms.filter((t) => t.type === \"owl:DatatypeProperty\"),\n  };\n}\n\n/**\n * Source-indicator badge.\n * CSS class encodes the source kind; aria-label carries the raw ecm: value\n * so Playwright can assert either (AC2: CSS class OR aria-label).\n */\nfunction SourceBadge({ source }: { source: string | undefined }) {\n  if (source === undefined) return null;\n  const label =\n    source === \"ecm:imported-ontology\"\n      ? \"imported\"\n      : source === \"ecm:project-created\"\n      ? \"project-created\"\n      : source === \"ecm:system-starter-example\"\n      ? \"starter\"\n      : source;\n  const cssModifier =\n    source === \"ecm:imported-ontology\"\n      ? \"gw-badge--imported\"\n      : source === \"ecm:project-created\"\n      ? \"gw-badge--project-created\"\n      : source === \"ecm:system-starter-example\"\n      ? \"gw-badge--starter\"\n      : \"gw-badge--unknown\";\n  return (\n    <span className={`gw-badge ${cssModifier}`} aria-label={source}>\n      {label}\n    </span>\n  );\n}\n\n/** One type-section: header + item list or empty-state message. */\nfunction TermSection({\n  title,\n  terms,\n  testId,\n}: {\n  title: string;\n  terms: TermEntry[];\n  testId: string;\n}) {\n  return (\n    <section className=\"gw-term-section\" data-testid={testId}>\n      <h3 className=\"gw-term-section-title\">{title}</h3>\n      {terms.length === 0 ? (\n        <p className=\"gw-term-empty\">No {title.toLowerCase()} yet</p>\n      ) : (\n        <ul className=\"gw-term-list\">\n          {terms.map((term) => {\n            const displayLabel =\n              typeof term[\"rdfs:label\"] === \"string\" &&\n              term[\"rdfs:label\"].length > 0\n                ? term[\"rdfs:label\"]\n                : iriTail(term.id);\n            return (\n              <li\n                key={term.id}\n                className=\"gw-term-item\"\n                data-testid=\"gw-term-item\"\n              >\n                <span className=\"gw-term-label\">{displayLabel}</span>\n                <SourceBadge source={term[\"ecm:source\"]} />\n              </li>\n            );\n          })}\n        </ul>\n      )}\n    </section>\n  );\n}\n\n/** Left-sidebar Term Manager (SPEC \u00a726, FR-U004, FR-U005). */\nexport function TermSidebar({ project }: TermSidebarProps) {\n  const { classes, objectProperties, datatypeProperties } =\n    partitionTerms(project);\n  return (\n    <>\n      <TermSection\n        title=\"Classes\"\n        terms={classes}\n        testId=\"gw-term-section-classes\"\n      />\n      <TermSection\n        title=\"Object Properties\"\n        terms={objectProperties}\n        testId=\"gw-term-section-object-properties\"\n      />\n      <TermSection\n        title=\"Datatype Properties\"\n        terms={datatypeProperties}\n        testId=\"gw-term-section-datatype-properties\"\n      />\n    </>\n  );\n}\n",
            "scope": "minimal"
          },
          {
            "id": "C2",
            "file": "src/ui/App.tsx",
            "rationale": "Add TermSidebar import. Placed immediately after App.css import, before migrate import, to group UI-layer imports together.",
            "before": "import { useState, useRef, type ChangeEvent } from \"react\";\nimport \"./App.css\";\nimport { migrate } from \"../migrate/index.js\";",
            "after": "import { useState, useRef, type ChangeEvent } from \"react\";\nimport \"./App.css\";\nimport { TermSidebar } from \"./TermSidebar.js\";\nimport { migrate } from \"../migrate/index.js\";",
            "scope": "minimal"
          },
          {
            "id": "C3",
            "file": "src/ui/App.tsx",
            "rationale": "Replace sidebar placeholder with TermSidebar component. Passes the project state prop (already lifted to App level per F2); no new state management.",
            "before": "        <aside className=\"gw-sidebar\" data-testid=\"gw-sidebar\">\n          <p className=\"gw-placeholder\">Term Manager -- task 2.2</p>\n        </aside>",
            "after": "        <aside className=\"gw-sidebar\" data-testid=\"gw-sidebar\">\n          <TermSidebar project={project} />\n        </aside>",
            "scope": "minimal"
          },
          {
            "id": "C4",
            "file": "src/ui/App.css",
            "rationale": "Append TermSidebar styles. Covers section layout, section title, empty-state text, term item row, and three source-indicator badge variants (imported/project-created/starter) plus an unknown fallback. Consistent with existing color palette.",
            "before": ".gw-migration-dismiss {\n  border: none;\n  background: transparent;\n  color: #fef9c3;\n  cursor: pointer;\n  font-size: 0.875rem;\n  padding: 0 0.25rem;\n  line-height: 1;\n}",
            "after": ".gw-migration-dismiss {\n  border: none;\n  background: transparent;\n  color: #fef9c3;\n  cursor: pointer;\n  font-size: 0.875rem;\n  padding: 0 0.25rem;\n  line-height: 1;\n}\n\n/* -----------------------------------------------------------------------\n * Term Sidebar (FR-U004 / FR-U005 -- task 2.2)\n * --------------------------------------------------------------------- */\n\n.gw-term-section {\n  margin-bottom: 1rem;\n}\n\n.gw-term-section-title {\n  font-size: 0.75rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  color: #64748b;\n  margin-bottom: 0.375rem;\n  padding-bottom: 0.25rem;\n  border-bottom: 1px solid #e2e8f0;\n}\n\n.gw-term-empty {\n  font-size: 0.8125rem;\n  color: #94a3b8;\n  font-style: italic;\n  padding: 0.25rem 0;\n}\n\n.gw-term-list {\n  list-style: none;\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n}\n\n.gw-term-item {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 0.5rem;\n  padding: 0.25rem 0.375rem;\n  border-radius: 3px;\n  font-size: 0.8125rem;\n}\n\n.gw-term-item:hover {\n  background: #e2e8f0;\n}\n\n.gw-term-label {\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n  color: #1e293b;\n  flex: 1;\n}\n\n.gw-badge {\n  flex-shrink: 0;\n  font-size: 0.625rem;\n  font-weight: 600;\n  padding: 0.125rem 0.375rem;\n  border-radius: 9999px;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n}\n\n.gw-badge--imported {\n  background: #dbeafe;\n  color: #1d4ed8;\n}\n\n.gw-badge--project-created {\n  background: #dcfce7;\n  color: #15803d;\n}\n\n.gw-badge--starter {\n  background: #fef3c7;\n  color: #b45309;\n}\n\n.gw-badge--unknown {\n  background: #f1f5f9;\n  color: #64748b;\n}\n",
            "scope": "minimal"
          },
          {
            "id": "C5",
            "file": "tests/playwright/term-sidebar.spec.ts",
            "rationale": "New Playwright spec covering AC1 (section item counts) and AC2 (project-created badge assertion via aria-label). Follows existing test patterns from shell.spec.ts and new-open-save.spec.ts: page.goto('/'), setInputFiles, await save enabled, then section-scoped getByTestId queries.",
            "before": null,
            "after": "import { test, expect } from \"@playwright/test\";\nimport path from \"path\";\n\n/**\n * Task 2.2 -- Term Sidebar acceptance tests.\n *\n * AC1: Project with 2 classes, 1 object property, 1 datatype property shows\n *      exactly those entries in the correct sidebar sections.\n * AC2: A ecm:project-created term shows the \"project-created\" indicator\n *      (aria-label=\"ecm:project-created\" assertion).\n */\n\nconst SIDEBAR_FIXTURE = path.join(\n  process.cwd(),\n  \"tests\",\n  \"playwright\",\n  \"fixtures\",\n  \"term-sidebar-2c-1op-1dp.jsonld\",\n);\n\ntest.describe(\"TermSidebar (task 2.2)\", () => {\n  test(\"AC1: 2 classes / 1 object property / 1 datatype property in correct sections\", async ({\n    page,\n  }) => {\n    await page.goto(\"/\");\n\n    // FR-U002: load fixture via hidden file input\n    await page.getByTestId(\"gw-file-input\").setInputFiles(SIDEBAR_FIXTURE);\n\n    // Wait for async FileReader + React state update\n    await expect(page.getByTestId(\"gw-btn-save\")).toBeEnabled();\n\n    const classesSec = page.getByTestId(\"gw-term-section-classes\");\n    const opSec = page.getByTestId(\"gw-term-section-object-properties\");\n    const dpSec = page.getByTestId(\"gw-term-section-datatype-properties\");\n\n    await expect(classesSec.getByTestId(\"gw-term-item\")).toHaveCount(2);\n    await expect(opSec.getByTestId(\"gw-term-item\")).toHaveCount(1);\n    await expect(dpSec.getByTestId(\"gw-term-item\")).toHaveCount(1);\n  });\n\n  test(\"AC2: ecm:project-created term shows project-created source indicator\", async ({\n    page,\n  }) => {\n    await page.goto(\"/\");\n\n    await page.getByTestId(\"gw-file-input\").setInputFiles(SIDEBAR_FIXTURE);\n    await expect(page.getByTestId(\"gw-btn-save\")).toBeEnabled();\n\n    // Badge aria-label carries the raw ecm: source value (TermSidebar.tsx AC2 contract).\n    const badge = page.locator('[aria-label=\"ecm:project-created\"]').first();\n    await expect(badge).toBeVisible();\n    await expect(badge).toHaveClass(/gw-badge--project-created/);\n  });\n});\n",
            "scope": "minimal"
          },
          {
            "id": "C6",
            "file": "tests/playwright/fixtures/term-sidebar-2c-1op-1dp.jsonld",
            "rationale": "Canonical v0.4 fixture with 2 owl:Class terms, 1 owl:ObjectProperty, 1 owl:DatatypeProperty. Covers all three ecm:source values. Term objects sorted by id (SPEC \u00c2\u00a75.3 rule 4); nested keys alphabetical (rule 3); top-level key order: @context, id, type, ecm:specVersion, then alphabetical remainder (rule 2). No BOM; LF line endings. The @context is identical to the minimal-v0.4 fixture (same VMP_CONTEXT).",
            "before": null,
