      "inputs": {
        "task_context": "Phase 1 task 1.11: CLI Surface implementation proposal",
        "output_envelope_constraint": "Output wrapped: outputs.changes[], outputs.summary, outputs.self_assessment.",
        "goal": "Propose changes[] implementing the Node CLI per IMPLEMENTATION_PLAN.md section 1.11.",
