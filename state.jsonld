            "before": "        <label className=\"gw-form-label\">\n          IRI override{\" \"}\n          <span className=\"gw-form-hint\">(optional; auto-generated if empty)</span>\n          <input\n            className=\"gw-form-input\"\n            type=\"text\"\n            value={iriOverride}\n            onChange={(e) => {\n              setIriOverride(e.target.value);\n              setError(null);\n            }}\n            data-testid=\"gw-input-term-iri\"\n          />\n        </label>\n        <div className=\"gw-form-actions\">\n          <button\n            type=\"button\"\n            className=\"gw-btn gw-btn--secondary\"\n            onClick={onClose}\n            data-testid=\"gw-btn-term-cancel\"\n          >\n            Cancel\n          </button>\n          <button\n            type=\"submit\"\n            className=\"gw-btn\"\n            data-testid=\"gw-btn-term-submit\"\n          >\n            Add {typeLabel}\n          </button>\n        </div>",
            "after": "        <label className=\"gw-form-label\">\n          IRI override{\" \"}\n          <span className=\"gw-form-hint\">(optional; auto-generated if empty)</span>\n          <input\n            className=\"gw-form-input\"\n            type=\"text\"\n            value={iriOverride}\n            onChange={(e) => {\n              setIriOverride(e.target.value);\n              setError(null);\n            }}\n            data-testid=\"gw-input-term-iri\"\n          />\n        </label>\n        {isDuplicate && (\n          <p\n            className=\"gw-iri-duplicate-warning\"\n            role=\"alert\"\n            data-testid=\"gw-iri-duplicate-warning\"\n          >\n            IRI already exists in this project: {trimmedIriOverride}\n          </p>\n        )}\n        <div className=\"gw-form-actions\">\n          <button\n            type=\"button\"\n            className=\"gw-btn gw-btn--secondary\"\n            onClick={onClose}\n            data-testid=\"gw-btn-term-cancel\"\n          >\n            Cancel\n          </button>\n          <button\n            type=\"submit\"\n            className=\"gw-btn\"\n            disabled={isDuplicate}\n            data-testid=\"gw-btn-term-submit\"\n          >\n            Add {typeLabel}\n          </button>\n        </div>",
