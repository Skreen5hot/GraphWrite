            "file": "src/ui/EditTermDialog.tsx",
            "rationale": "AC3 (FR-U013): add the 'Regenerate IRI' button (data-testid='gw-btn-regenerate-iri') immediately after the IRI label's closing tag, before the form-actions div. Placed outside the <label> element to avoid the button click delegating focus to the IRI input. Uses gw-btn--secondary style consistent with the Cancel button pattern across the dialog suite.",
            "before": "        <label className=\"gw-form-label\">\n          IRI\n          <input\n            className=\"gw-form-input\"\n            type=\"text\"\n            value={iri}\n            onChange={(e) => {\n              setIri(e.target.value);\n              setError(null);\n            }}\n            data-testid=\"gw-input-edit-iri\"\n          />\n        </label>\n        <div className=\"gw-form-actions\">",
