    {
      "@id": "urn:fnsr:task:171-dev-term-crud",
      "agent": "developer",
      "status": "done",
      "attempts": 1,
      "outputs": {
        "changes": [
          {
            "id": "C1",
            "file": "src/ui/Dialog.tsx",
            "rationale": "Generic modal dialog primitive. Uses native <dialog> element for backdrop + Escape handling. Mount/unmount pattern: parent renders {open && <Dialog>}. Cleanup removes event listener before calling el.close() so the synchronous close event does not re-invoke onClose during unmount.",
            "before": null,
            "after": "/**\n * Dialog -- generic modal dialog primitive (task 2.3 Chain A).\n *\n * Uses the native HTML <dialog> element: backdrop, Escape-to-close, and\n * focus management are browser-provided. showModal() is called on mount.\n *\n * Mount/unmount pattern -- parent controls visibility:\n *   {open && <Dialog title=\"...\" onClose={fn}>...</Dialog>}\n *\n * FR-U006 / FR-U007 / FR-U008 / FR-U009.\n */\n\nimport { useEffect, useRef, type ReactNode } from \"react\";\n\ninterface DialogProps {\n  title: string;\n  onClose: () => void;\n  children: ReactNode;\n  /** data-testid on the <dialog> element. Defaults to \"gw-dialog\". */\n  testId?: string;\n}\n\nexport function Dialog({\n  title,\n  onClose,\n  children,\n  testId = \"gw-dialog\",\n}: DialogProps) {\n  const ref = useRef<HTMLDialogElement>(null);\n  /** Stable ref so the single-mount effect always calls the latest onClose. */\n  const onCloseRef = useRef(onClose);\n  onCloseRef.current = onClose;\n\n  useEffect(() => {\n    const el = ref.current;\n    if (el == null) return;\n    const handleClose = () => {\n      onCloseRef.current();\n    };\n    el.addEventListener(\"close\", handleClose);\n    if (!el.open) el.showModal();\n    return () => {\n      // Remove listener BEFORE el.close() so the close event fired by\n      // el.close() has no listener and does not re-call onClose.\n      el.removeEventListener(\"close\", handleClose);\n      if (el.open) el.close();\n    };\n  }, []);\n\n  return (\n    <dialog ref={ref} className=\"gw-dialog\" data-testid={testId}>\n      <div className=\"gw-dialog-header\">\n        <h2 className=\"gw-dialog-title\">{title}</h2>\n        <button\n          type=\"button\"\n          className=\"gw-dialog-close\"\n          onClick={onClose}\n          aria-label=\"Close dialog\"\n        >\n          &#x2715;\n        </button>\n      </div>\n      <div className=\"gw-dialog-body\">{children}</div>\n    </dialog>\n  );\n}\n",
            "scope": "moderate"
          },
          {
            "id": "C2",
            "file": "src/ui/AddTermDialog.tsx",
            "rationale": "Add-term form for FR-U006/007/008. Uses crypto.randomUUID() (Web Crypto API, typed in lib:DOM) because src/iri/index.ts imports node:crypto and cannot be imported in a browser bundle. Inline IRI-uniqueness check because collectSemanticEntityIds in src/refactor/index.ts is not exported (recon F13). Term shape per SPEC \u00c2\u00a75.7. onConfirm hands the new entry to TermSidebar which appends, sorts, and closes.",
            "before": null,
            "after": "/**\n * AddTermDialog -- form for FR-U006 / FR-U007 / FR-U008 (task 2.3 Chain A).\n *\n * IRI generation: uses crypto.randomUUID() (Web Crypto API; browser-native;\n * typed in tsconfig.ui.json lib:DOM) when no IRI override is supplied.\n * src/iri/index.ts uses node:crypto and is not importable in a browser bundle.\n * See open_questions in urn:fnsr:task:171-dev-term-crud for the recommended\n * browser-compat export track for src/iri/.\n *\n * Term shape: SPEC \u00a75.7.\n */\n\nimport { useState, type FormEvent } from \"react\";\nimport { Dialog } from \"./Dialog.js\";\n\nexport type AddTermType =\n  | \"owl:Class\"\n  | \"owl:ObjectProperty\"\n  | \"owl:DatatypeProperty\";\n\ninterface AddTermDialogProps {\n  termType: AddTermType;\n  /** Read-only; used for IRI uniqueness check. */\n  project: Record<string, unknown>;\n  /** Called with the new SPEC \u00a75.7-shaped term entry on successful submit. */\n  onConfirm: (newTerm: Record<string, unknown>) => void;\n  onClose: () => void;\n}\n\nconst TERM_TYPE_LABEL: Record<AddTermType, string> = {\n  \"owl:Class\": \"Class\",\n  \"owl:ObjectProperty\": \"Object Property\",\n  \"owl:DatatypeProperty\": \"Datatype Property\",\n};\n\n/**\n * Collect all id values from ecm:terms + ecm:instances for duplicate-IRI\n * detection. Inline because collectSemanticEntityIds in src/refactor/index.ts\n * is not exported (reconnaissance finding F13).\n */\nfunction collectExistingIris(project: Record<string, unknown>): Set<string> {\n  const iris = new Set<string>();\n  for (const key of [\"ecm:terms\", \"ecm:instances\"]) {\n    const arr = project[key];\n    if (!Array.isArray(arr)) continue;\n    for (const item of arr as unknown[]) {\n      if (typeof item !== \"object\" || item === null) continue;\n      const id = (item as Record<string, unknown>)[\"id\"];\n      if (typeof id === \"string\" && id.length > 0) iris.add(id);\n    }\n  }\n  return iris;\n}\n\nexport function AddTermDialog({\n  termType,\n  project,\n  onConfirm,\n  onClose,\n}: AddTermDialogProps) {\n  const [label, setLabel] = useState(\"\");\n  const [iriOverride, setIriOverride] = useState(\"\");\n  const [error, setError] = useState<string | null>(null);\n\n  function handleSubmit(e: FormEvent<HTMLFormElement>) {\n    e.preventDefault();\n    const trimmedLabel = label.trim();\n    if (trimmedLabel.length === 0) {\n      setError(\"Label is required.\");\n      return;\n    }\n    const trimmedIri = iriOverride.trim();\n    const iri =\n      trimmedIri.length > 0\n        ? trimmedIri\n        : `urn:uuid:${crypto.randomUUID()}`;\n    if (collectExistingIris(project).has(iri)) {\n      setError(`IRI already exists in this project: ${iri}`);\n      return;\n    }\n    const now = new Date().toISOString();\n    const newTerm: Record<string, unknown> = {\n      \"ecm:createdAt\": now,\n      \"ecm:ontologyId\": null,\n      \"ecm:source\": \"ecm:project-created\",\n      \"ecm:updatedAt\": now,\n      id: iri,\n      \"rdfs:label\": trimmedLabel,\n      type: termType,\n    };\n    onConfirm(newTerm);\n  }\n\n  const typeLabel = TERM_TYPE_LABEL[termType];\n\n  return (\n    <Dialog\n      title={`Add ${typeLabel}`}\n      onClose={onClose}\n      testId=\"gw-dialog-add-term\"\n    >\n      <form\n        className=\"gw-term-form\"\n        onSubmit={handleSubmit}\n        data-testid=\"gw-form-add-term\"\n      >\n        {error !== null && (\n          <p className=\"gw-form-error\" role=\"alert\" data-testid=\"gw-form-error\">\n            {error}\n          </p>\n        )}\n        <label className=\"gw-form-label\">\n          Label *\n          <input\n            className=\"gw-form-input\"\n            type=\"text\"\n            value={label}\n            onChange={(e) => {\n              setLabel(e.target.value);\n              setError(null);\n            }}\n            data-testid=\"gw-input-term-label\"\n            autoFocus\n          />\n        </label>\n        <label className=\"gw-form-label\">\n          IRI override{\" \"}\n          <span className=\"gw-form-hint\">(optional; auto-generated if empty)</span>\n          <input\n            className=\"gw-form-input\"\n            type=\"text\"\n            value={iriOverride}\n            onChange={(e) => {\n              setIriOverride(e.target.value);\n              setError(null);\n            }}\n            data-testid=\"gw-input-term-iri\"\n          />\n        </label>\n        <div className=\"gw-form-actions\">\n          <button\n            type=\"button\"\n            className=\"gw-btn gw-btn--secondary\"\n            onClick={onClose}\n            data-testid=\"gw-btn-term-cancel\"\n          >\n            Cancel\n          </button>\n          <button\n            type=\"submit\"\n            className=\"gw-btn\"\n            data-testid=\"gw-btn-term-submit\"\n          >\n            Add {typeLabel}\n          </button>\n        </div>\n      </form>\n    </Dialog>\n  );\n}\n",
            "scope": "moderate"
          },
          {
            "id": "C3",
            "file": "src/ui/TermSidebar.tsx",
            "rationale": "Full replacement. Adds: (1) imports for useState + AddTermDialog; (2) onTermsChange? callback on TermSidebarProps; (3) gw-term-section-header wrapper div + optional Add button in TermSection; (4) addDialogType state + handleAddConfirm (appends new term, sorts ecm:terms by id per SPEC \u00c2\u00a75.3 rule 4, calls onTermsChange, closes dialog) + conditional AddTermDialog render in TermSidebar. canEdit guard keeps Add buttons hidden when project is null or callback is absent.",
            "before": "/**\n * TermSidebar -- task 2.2 Term Manager left sidebar.\n *\n * Renders three sections (Classes, Object Properties, Datatype Properties)\n * from the canonical project document's ecm:terms array.\n * Source-indicator badges carry both CSS class + aria-label per AC2.\n * SPEC \u00a75.7 / FR-U004 / FR-U005.\n */\n\n/** Shape of a single ecm:terms entry (SPEC \u00a75.7). */\ninterface TermEntry {\n  id: string;\n  type: string;\n  \"rdfs:label\"?: string;\n  \"ecm:source\"?: string;\n}\n\ninterface TermSidebarProps {\n  project: Record<string, unknown> | null;\n}\n\n/** Extract the IRI tail (fragment after last '#' or last path segment). */\nfunction iriTail(iri: string): string {\n  const hash = iri.lastIndexOf(\"#\");\n  const slash = iri.lastIndexOf(\"/\");\n  const idx = Math.max(hash, slash);\n  return idx >= 0 ? iri.slice(idx + 1) : iri;\n}\n\n/** Coerce an ecm:terms array element to TermEntry; returns null if malformed. */\nfunction toTermEntry(item: unknown): TermEntry | null {\n  if (typeof item !== \"object\" || item === null) return null;\n  const obj = item as Record<string, unknown>;\n  if (typeof obj[\"id\"] !== \"string\") return null;\n  return obj as unknown as TermEntry;\n}\n\n/** Partition the project's ecm:terms into typed buckets. */\nfunction partitionTerms(project: Record<string, unknown> | null): {\n  classes: TermEntry[];\n  objectProperties: TermEntry[];\n  datatypeProperties: TermEntry[];\n} {\n  if (project === null) {\n    return { classes: [], objectProperties: [], datatypeProperties: [] };\n  }\n  const raw = project[\"ecm:terms\"];\n  if (!Array.isArray(raw)) {\n    return { classes: [], objectProperties: [], datatypeProperties: [] };\n  }\n  const terms = (raw as unknown[])\n    .map(toTermEntry)\n    .filter((t): t is TermEntry => t !== null);\n  return {\n    classes: terms.filter((t) => t.type === \"owl:Class\"),\n    objectProperties: terms.filter((t) => t.type === \"owl:ObjectProperty\"),\n    datatypeProperties: terms.filter((t) => t.type === \"owl:DatatypeProperty\"),\n  };\n}\n\n/**\n * Source-indicator badge.\n * CSS class encodes the source kind; aria-label carries the raw ecm: value\n * so Playwright can assert either (AC2: CSS class OR aria-label).\n */\nfunction SourceBadge({ source }: { source: string | undefined }) {\n  if (source === undefined) return null;\n  const label =\n    source === \"ecm:imported-ontology\"\n      ? \"imported\"\n      : source === \"ecm:project-created\"\n      ? \"project-created\"\n      : source === \"ecm:system-starter-example\"\n      ? \"starter\"\n      : source;\n  const cssModifier =\n    source === \"ecm:imported-ontology\"\n      ? \"gw-badge--imported\"\n      : source === \"ecm:project-created\"\n      ? \"gw-badge--project-created\"\n      : source === \"ecm:system-starter-example\"\n      ? \"gw-badge--starter\"\n      : \"gw-badge--unknown\";\n  return (\n    <span className={`gw-badge ${cssModifier}`} aria-label={source}>\n      {label}\n    </span>\n  );\n}\n\n/** One type-section: header + item list or empty-state message. */\nfunction TermSection({\n  title,\n  terms,\n  testId,\n}: {\n  title: string;\n  terms: TermEntry[];\n  testId: string;\n}) {\n  return (\n    <section className=\"gw-term-section\" data-testid={testId}>\n      <h3 className=\"gw-term-section-title\">{title}</h3>\n      {terms.length === 0 ? (\n        <p className=\"gw-term-empty\">No {title.toLowerCase()} yet</p>\n      ) : (\n        <ul className=\"gw-term-list\">\n          {terms.map((term) => {\n            const displayLabel =\n              typeof term[\"rdfs:label\"] === \"string\" &&\n              term[\"rdfs:label\"].length > 0\n                ? term[\"rdfs:label\"]\n                : iriTail(term.id);\n            return (\n              <li\n                key={term.id}\n                className=\"gw-term-item\"\n                data-testid=\"gw-term-item\"\n              >\n                <span className=\"gw-term-label\">{displayLabel}</span>\n                <SourceBadge source={term[\"ecm:source\"]} />\n              </li>\n            );\n          })}\n        </ul>\n      )}\n    </section>\n  );\n}\n\n/** Left-sidebar Term Manager (SPEC \u00a726, FR-U004, FR-U005). */\nexport function TermSidebar({ project }: TermSidebarProps) {\n  const { classes, objectProperties, datatypeProperties } =\n    partitionTerms(project);\n  return (\n    <>\n      <TermSection\n        title=\"Classes\"\n        terms={classes}\n        testId=\"gw-term-section-classes\"\n      />\n      <TermSection\n        title=\"Object Properties\"\n        terms={objectProperties}\n        testId=\"gw-term-section-object-properties\"\n      />\n      <TermSection\n        title=\"Datatype Properties\"\n        terms={datatypeProperties}\n        testId=\"gw-term-section-datatype-properties\"\n      />\n    </>\n  );\n}\n",
            "after": "/**\n * TermSidebar -- task 2.2 Term Manager left sidebar.\n * Extended in task 2.3 Chain A: Add term (FR-U006 / FR-U007 / FR-U008).\n *\n * Renders three sections (Classes, Object Properties, Datatype Properties)\n * from the canonical project document's ecm:terms array.\n * Source-indicator badges carry both CSS class + aria-label per AC2.\n * SPEC \u00a75.7 / FR-U004 / FR-U005 / FR-U006 / FR-U007 / FR-U008.\n */\n\nimport { useState } from \"react\";\nimport { AddTermDialog, type AddTermType } from \"./AddTermDialog.js\";\n\n/** Shape of a single ecm:terms entry (SPEC \u00a75.7). */\ninterface TermEntry {\n  id: string;\n  type: string;\n  \"rdfs:label\"?: string;\n  \"ecm:source\"?: string;\n}\n\ninterface TermSidebarProps {\n  project: Record<string, unknown> | null;\n  /**\n   * Called with the updated project document after a term is added.\n   * When undefined the Add buttons are hidden (read-only mode).\n   */\n  onTermsChange?: (project: Record<string, unknown>) => void;\n}\n\n/** Extract the IRI tail (fragment after last '#' or last path segment). */\nfunction iriTail(iri: string): string {\n  const hash = iri.lastIndexOf(\"#\");\n  const slash = iri.lastIndexOf(\"/\");\n  const idx = Math.max(hash, slash);\n  return idx >= 0 ? iri.slice(idx + 1) : iri;\n}\n\n/** Coerce an ecm:terms array element to TermEntry; returns null if malformed. */\nfunction toTermEntry(item: unknown): TermEntry | null {\n  if (typeof item !== \"object\" || item === null) return null;\n  const obj = item as Record<string, unknown>;\n  if (typeof obj[\"id\"] !== \"string\") return null;\n  return obj as unknown as TermEntry;\n}\n\n/** Partition the project's ecm:terms into typed buckets. */\nfunction partitionTerms(project: Record<string, unknown> | null): {\n  classes: TermEntry[];\n  objectProperties: TermEntry[];\n  datatypeProperties: TermEntry[];\n} {\n  if (project === null) {\n    return { classes: [], objectProperties: [], datatypeProperties: [] };\n  }\n  const raw = project[\"ecm:terms\"];\n  if (!Array.isArray(raw)) {\n    return { classes: [], objectProperties: [], datatypeProperties: [] };\n  }\n  const terms = (raw as unknown[])\n    .map(toTermEntry)\n    .filter((t): t is TermEntry => t !== null);\n  return {\n    classes: terms.filter((t) => t.type === \"owl:Class\"),\n    objectProperties: terms.filter((t) => t.type === \"owl:ObjectProperty\"),\n    datatypeProperties: terms.filter((t) => t.type === \"owl:DatatypeProperty\"),\n  };\n}\n\n/**\n * Source-indicator badge.\n * CSS class encodes the source kind; aria-label carries the raw ecm: value\n * so Playwright can assert either (AC2: CSS class OR aria-label).\n */\nfunction SourceBadge({ source }: { source: string | undefined }) {\n  if (source === undefined) return null;\n  const label =\n    source === \"ecm:imported-ontology\"\n      ? \"imported\"\n      : source === \"ecm:project-created\"\n      ? \"project-created\"\n      : source === \"ecm:system-starter-example\"\n      ? \"starter\"\n      : source;\n  const cssModifier =\n    source === \"ecm:imported-ontology\"\n      ? \"gw-badge--imported\"\n      : source === \"ecm:project-created\"\n      ? \"gw-badge--project-created\"\n      : source === \"ecm:system-starter-example\"\n      ? \"gw-badge--starter\"\n      : \"gw-badge--unknown\";\n  return (\n    <span className={`gw-badge ${cssModifier}`} aria-label={source}>\n      {label}\n    </span>\n  );\n}\n\n/**\n * One type-section: header (with optional Add button) + item list or empty-state.\n * onAddTerm is only passed when a project is open and onTermsChange is wired.\n */\nfunction TermSection({\n  title,\n  terms,\n  testId,\n  onAddTerm,\n  addTestId,\n}: {\n  title: string;\n  terms: TermEntry[];\n  testId: string;\n  onAddTerm?: () => void;\n  addTestId?: string;\n}) {\n  return (\n    <section className=\"gw-term-section\" data-testid={testId}>\n      <div className=\"gw-term-section-header\">\n        <h3 className=\"gw-term-section-title\">{title}</h3>\n        {onAddTerm !== undefined && (\n          <button\n            type=\"button\"\n            className=\"gw-btn-add-term\"\n            onClick={onAddTerm}\n            aria-label={`Add ${title}`}\n            data-testid={addTestId}\n          >\n            +\n          </button>\n        )}\n      </div>\n      {terms.length === 0 ? (\n        <p className=\"gw-term-empty\">No {title.toLowerCase()} yet</p>\n      ) : (\n        <ul className=\"gw-term-list\">\n          {terms.map((term) => {\n            const displayLabel =\n              typeof term[\"rdfs:label\"] === \"string\" &&\n              term[\"rdfs:label\"].length > 0\n                ? term[\"rdfs:label\"]\n                : iriTail(term.id);\n            return (\n              <li\n                key={term.id}\n                className=\"gw-term-item\"\n                data-testid=\"gw-term-item\"\n              >\n                <span className=\"gw-term-label\">{displayLabel}</span>\n                <SourceBadge source={term[\"ecm:source\"]} />\n              </li>\n            );\n          })}\n        </ul>\n      )}\n    </section>\n  );\n}\n\n/** Left-sidebar Term Manager (SPEC \u00a726, FR-U004 through FR-U008). */\nexport function TermSidebar({ project, onTermsChange }: TermSidebarProps) {\n  /** OWL type of the term being added; null when the Add dialog is closed. */\n  const [addDialogType, setAddDialogType] = useState<AddTermType | null>(null);\n\n  const { classes, objectProperties, datatypeProperties } =\n    partitionTerms(project);\n\n  /**\n   * Append the confirmed new term to ecm:terms, sort by id (SPEC \u00a75.3 rule 4),\n   * propagate via onTermsChange, then close the dialog.\n   */\n  function handleAddConfirm(newTerm: Record<string, unknown>) {\n    if (project === null || onTermsChange === undefined) return;\n    const existing: unknown[] = Array.isArray(project[\"ecm:terms\"])\n      ? (project[\"ecm:terms\"] as unknown[])\n      : [];\n    const sorted = [...existing, newTerm].sort((a, b) => {\n      const aId =\n        typeof (a as Record<string, unknown>)[\"id\"] === \"string\"\n          ? ((a as Record<string, unknown>)[\"id\"] as string)\n          : \"\";\n      const bId =\n        typeof (b as Record<string, unknown>)[\"id\"] === \"string\"\n          ? ((b as Record<string, unknown>)[\"id\"] as string)\n          : \"\";\n      return aId < bId ? -1 : aId > bId ? 1 : 0;\n    });\n    onTermsChange({ ...project, \"ecm:terms\": sorted });\n    setAddDialogType(null);\n  }\n\n  // Add buttons are only visible when a project is open and the mutation\n  // callback is wired (read-only contexts pass no onTermsChange).\n  const canEdit = project !== null && onTermsChange !== undefined;\n\n  return (\n    <>\n      <TermSection\n        title=\"Classes\"\n        terms={classes}\n        testId=\"gw-term-section-classes\"\n        onAddTerm={canEdit ? () => setAddDialogType(\"owl:Class\") : undefined}\n        addTestId=\"gw-btn-add-class\"\n      />\n      <TermSection\n        title=\"Object Properties\"\n        terms={objectProperties}\n        testId=\"gw-term-section-object-properties\"\n        onAddTerm={\n          canEdit ? () => setAddDialogType(\"owl:ObjectProperty\") : undefined\n        }\n        addTestId=\"gw-btn-add-object-property\"\n      />\n      <TermSection\n        title=\"Datatype Properties\"\n        terms={datatypeProperties}\n        testId=\"gw-term-section-datatype-properties\"\n        onAddTerm={\n          canEdit\n            ? () => setAddDialogType(\"owl:DatatypeProperty\")\n            : undefined\n        }\n        addTestId=\"gw-btn-add-datatype-property\"\n      />\n      {addDialogType !== null && project !== null && (\n        <AddTermDialog\n          termType={addDialogType}\n          project={project}\n          onConfirm={handleAddConfirm}\n          onClose={() => setAddDialogType(null)}\n        />\n      )}\n    </>\n  );\n}\n",
            "scope": "moderate"
          },
          {
            "id": "C4",
            "file": "src/ui/App.tsx",
            "rationale": "Wire the new onTermsChange callback. setProject is React.Dispatch<SetStateAction<Record<string,unknown>|null>>; the lambda narrows the type to the non-null branch that TermSidebar's callback expects.",
            "before": "          <TermSidebar project={project} />",
            "after": "          <TermSidebar\n            project={project}\n            onTermsChange={(updated) => { setProject(updated); }}\n          />",
            "scope": "minimal"
          },
          {
            "id": "C5",
            "file": "src/ui/App.css",
            "rationale": "Split gw-term-section-title into a flex-row header container (gw-term-section-header) that holds the h3 + the Add button side by side. Move margin/padding/border-bottom to the container so the separator spans the full width.",
            "before": ".gw-term-section-title {\n  font-size: 0.75rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  color: #64748b;\n  margin-bottom: 0.375rem;\n  padding-bottom: 0.25rem;\n  border-bottom: 1px solid #e2e8f0;\n}",
            "after": ".gw-term-section-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 0.375rem;\n  padding-bottom: 0.25rem;\n  border-bottom: 1px solid #e2e8f0;\n}\n\n.gw-term-section-title {\n  font-size: 0.75rem;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  color: #64748b;\n}",
            "scope": "minimal"
          },
          {
            "id": "C6",
            "file": "src/ui/App.css",
            "rationale": "Append Add-button, dialog, and form CSS. Scoped to new class names introduced by Dialog.tsx, AddTermDialog.tsx, and the updated TermSection header.",
            "before": ".gw-badge--unknown {\n  background: #f1f5f9;\n  color: #64748b;\n}\n",
            "after": ".gw-badge--unknown {\n  background: #f1f5f9;\n  color: #64748b;\n}\n\n/* -----------------------------------------------------------------------\n * Term CRUD: Add-term button in section headers (FR-U006/007/008)\n * --------------------------------------------------------------------- */\n\n.gw-btn-add-term {\n  background: transparent;\n  border: 1px solid #94a3b8;\n  border-radius: 3px;\n  color: #64748b;\n  cursor: pointer;\n  font-size: 0.875rem;\n  line-height: 1;\n  padding: 0 0.3125rem;\n}\n\n.gw-btn-add-term:hover {\n  background: #e2e8f0;\n  border-color: #475569;\n  color: #1e293b;\n}\n\n/* -----------------------------------------------------------------------\n * Dialog (FR-U006 / FR-U007 / FR-U008 / FR-U009)\n * --------------------------------------------------------------------- */\n\ndialog.gw-dialog {\n  border: 1px solid #e2e8f0;\n  border-radius: 6px;\n  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);\n  padding: 0;\n  width: 22rem;\n  max-width: calc(100vw - 2rem);\n}\n\ndialog.gw-dialog::backdrop {\n  background: rgba(0, 0, 0, 0.35);\n}\n\n.gw-dialog-header {\n  align-items: center;\n  border-bottom: 1px solid #e2e8f0;\n  display: flex;\n  justify-content: space-between;\n  padding: 0.75rem 1rem;\n}\n\n.gw-dialog-title {\n  color: #1e293b;\n  font-size: 0.9375rem;\n  font-weight: 600;\n}\n\n.gw-dialog-close {\n  background: transparent;\n  border: none;\n  color: #64748b;\n  cursor: pointer;\n  font-size: 0.875rem;\n  line-height: 1;\n  padding: 0.125rem 0.25rem;\n}\n\n.gw-dialog-close:hover {\n  color: #1e293b;\n}\n\n.gw-dialog-body {\n  padding: 1rem;\n}\n\n/* -----------------------------------------------------------------------\n * Term add / edit form\n * --------------------------------------------------------------------- */\n\n.gw-term-form {\n  display: flex;\n  flex-direction: column;\n  gap: 0.875rem;\n}\n\n.gw-form-label {\n  color: #374151;\n  display: flex;\n  flex-direction: column;\n  font-size: 0.8125rem;\n  font-weight: 500;\n  gap: 0.25rem;\n}\n\n.gw-form-hint {\n  color: #6b7280;\n  font-size: 0.75rem;\n  font-weight: 400;\n}\n\n.gw-form-input {\n  border: 1px solid #d1d5db;\n  border-radius: 4px;\n  font-size: 0.875rem;\n  outline: none;\n  padding: 0.375rem 0.5rem;\n  width: 100%;\n}\n\n.gw-form-input:focus {\n  border-color: #3b82f6;\n  box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);\n}\n\n.gw-form-error {\n  background: #fef2f2;\n  border: 1px solid #fca5a5;\n  border-radius: 4px;\n  color: #b91c1c;\n  font-size: 0.8125rem;\n  padding: 0.375rem 0.5rem;\n}\n\n.gw-form-actions {\n  display: flex;\n  gap: 0.5rem;\n  justify-content: flex-end;\n  margin-top: 0.25rem;\n}\n\n.gw-btn--secondary {\n  background: transparent;\n  border-color: #94a3b8;\n  color: #475569;\n}\n\n.gw-btn--secondary:hover:not(:disabled) {\n  background: #f1f5f9;\n  border-color: #64748b;\n}\n",
            "scope": "minimal"
          },
          {
            "id": "C7",
            "file": "tests/playwright/term-crud.spec.ts",
            "rationale": "AC1 Playwright test. Loads the 2c/1op/1dp fixture, clicks the Add Class '+' button, fills label, submits, saves, re-parses the download, and asserts the new owl:Class entry is present with a urn:uuid: IRI. Follows the download.path() pattern established in new-open-save.spec.ts. AC2/AC3 deferred to Chain B; AC4 deferred to Chain C.",
            "before": null,
            "after": "import { test, expect } from \"@playwright/test\";\nimport path from \"path\";\nimport fs from \"fs\";\n\n/**\n * Task 2.3 Chain A -- Term CRUD acceptance tests.\n *\n * AC1: Add class form: new owl:Class entry appears in ecm:terms with a valid\n *      urn:uuid: IRI after save.\n *\n * Chain B (deferred): AC2 (Edit label) + AC3 (Edit IRI / Refactor-IRI dialog).\n * Chain C (deferred): AC4 (Imported term read-only stub).\n */\n\nconst SIDEBAR_FIXTURE = path.join(\n  process.cwd(),\n  \"tests\",\n  \"playwright\",\n  \"fixtures\",\n  \"term-sidebar-2c-1op-1dp.jsonld\",\n);\n\ntest.describe(\"Term CRUD (task 2.3 Chain A)\", () => {\n  test(\n    \"AC1: Add class -> Save -> re-parse: new owl:Class in ecm:terms with urn:uuid: IRI\",\n    async ({ page }) => {\n      await page.goto(\"/\");\n\n      // Load the 2-class / 1-OP / 1-DP fixture.\n      await page.getByTestId(\"gw-file-input\").setInputFiles(SIDEBAR_FIXTURE);\n      await expect(page.getByTestId(\"gw-btn-save\")).toBeEnabled();\n\n      // Open the Add Class dialog via the \"+\" button in the Classes section header.\n      await page.getByTestId(\"gw-btn-add-class\").click();\n      await expect(page.getByTestId(\"gw-dialog-add-term\")).toBeVisible();\n\n      // Fill in the label; leave IRI override blank for auto-generation.\n      await page.getByTestId(\"gw-input-term-label\").fill(\"Test Class\");\n\n      // Submit.\n      await page.getByTestId(\"gw-btn-term-submit\").click();\n\n      // Dialog must close after successful submit.\n      await expect(\n        page.getByTestId(\"gw-dialog-add-term\"),\n      ).not.toBeVisible();\n\n      // Classes section must now show 3 items (2 original + 1 new).\n      const classesSec = page.getByTestId(\"gw-term-section-classes\");\n      await expect(classesSec.getByTestId(\"gw-term-item\")).toHaveCount(3);\n\n      // Save and capture the downloaded file.\n      const [download] = await Promise.all([\n        page.waitForEvent(\"download\"),\n        page.getByTestId(\"gw-btn-save\").click(),\n      ]);\n\n      const downloadPath = await download.path();\n      expect(downloadPath, \"download must be saved to disk\").not.toBeNull();\n\n      const content = fs.readFileSync(downloadPath!, \"utf-8\");\n      const parsed = JSON.parse(content) as Record<string, unknown>;\n\n      // ecm:terms must contain the new entry.\n      const terms = parsed[\"ecm:terms\"];\n      expect(Array.isArray(terms), \"ecm:terms must be an array\").toBe(true);\n      const termArray = terms as Array<Record<string, unknown>>;\n\n      // Fixture has 4 terms; after adding 1 the total must be 5.\n      expect(\n        termArray.length,\n        \"ecm:terms length must be 5 after adding 1 term\",\n      ).toBe(5);\n\n      // Locate the new entry by label + source + type.\n      const newClass = termArray.find(\n        (t) =>\n          t[\"type\"] === \"owl:Class\" &&\n          t[\"rdfs:label\"] === \"Test Class\" &&\n          t[\"ecm:source\"] === \"ecm:project-created\",\n      );\n      expect(newClass, \"new owl:Class entry must be in ecm:terms\").toBeDefined();\n\n      // IRI must match the auto-generation policy (urn:uuid: prefix).\n      const newIri = newClass![\"id\"];\n      expect(typeof newIri, \"new term id must be a string\").toBe(\"string\");\n      expect(\n        (newIri as string).startsWith(\"urn:uuid:\"),\n        \"auto-generated IRI must start with urn:uuid:\",\n      ).toBe(true);\n    },\n  );\n});\n",
            "scope": "moderate"
          }
        ],
        "tests_recommended": [
          {
            "file": "tests/playwright/term-crud.spec.ts",
            "describe": "Chain B: AC2 (click project-created term \u00e2\u2020\u2019 Edit dialog pre-populated \u00e2\u2020\u2019 change label \u00e2\u2020\u2019 save \u00e2\u2020\u2019 reparse: rdfs:label updated). AC3 (change IRI field \u00e2\u2020\u2019 Refactor-IRI confirmation dialog appears showing referenceCount from refactorIri() \u00e2\u2020\u2019 confirm \u00e2\u2020\u2019 save \u00e2\u2020\u2019 reparse: old IRI gone, new IRI present). Requires EditTermDialog component + integration with src/refactor/index.ts."
          },
          {
