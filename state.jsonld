            "id": "F2",
            "claim": "The @xyflow/react v12 ReactFlowProps interface declares onNodeDragStop with type OnNodeDrag<NodeType>, documented as 'called when a user stops dragging a node'; its signature is (event: ReactMouseEvent, node: NodeType, nodes: NodeType[]) => void.",
            "evidence": [
