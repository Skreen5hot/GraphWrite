                "lines": "104-116",
                "excerpt": "function TermSection({\n  title,\n  terms,\n  testId,\n  onAddTerm,\n  addTestId,\n}: {\n  title: string;\n  terms: TermEntry[];\n  testId: string;\n  onAddTerm?: () => void;\n  addTestId?: string;\n})"
              },
              {
                "file": "src/ui/TermSidebar.tsx",
