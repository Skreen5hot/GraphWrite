            "before": "interface CanvasViewInnerProps {\n  nodes: InstanceNode[];\n  edges: RelationEdge[];\n  project: Record<string, unknown>;\n  onProjectChange?: (updated: Record<string, unknown>) => void;\n}",
            "after": "interface CanvasViewInnerProps {\n  nodes: InstanceNode[];\n  edges: RelationEdge[];\n  project: Record<string, unknown>;\n  onProjectChange?: (updated: Record<string, unknown>) => void;\n  onEdgeSelect?: (relationId: string | null) => void;\n}",
            "scope": "minimal"
          },
          {
            "id": "C4",
            "file": "src/ui/CanvasView.tsx",
            "rationale": "Destructure onEdgeSelect inside CanvasViewInner so it is available to handlers.",
            "before": "function CanvasViewInner({\n  nodes,\n  edges,\n  project,\n  onProjectChange,\n}: CanvasViewInnerProps) {\n  const { screenToFlowPosition } = useReactFlow();",
            "after": "function CanvasViewInner({\n  nodes,\n  edges,\n  project,\n  onProjectChange,\n  onEdgeSelect,\n}: CanvasViewInnerProps) {\n  const { screenToFlowPosition } = useReactFlow();",
            "scope": "minimal"
          },
          {
            "id": "C5",
            "file": "src/ui/CanvasView.tsx",
            "rationale": "Add handleConnect (FR-U014: creates ecm:RelationAssertion with placeholder predicateIri) and handleEdgeClick (FR-U015/U016/U017 prerequisite: notifies App of selected edge). Enable nodesConnectable and elementsSelectable conditionally (mirror nodesDraggable pattern). Wire onConnect and onEdgeClick on ReactFlow.",
            "before": "    },\n    [onProjectChange, project],\n  );\n\n  return (\n    <ReactFlow\n      nodes={nodes}\n      edges={edges}\n      nodesDraggable={onProjectChange !== undefined}\n      nodesConnectable={false}\n      elementsSelectable={false}\n      fitView={nodes.length > 0}\n      onPaneClick={handlePaneClick}\n      onNodeDragStop={handleNodeDragStop}\n    >\n      <Background />\n      <Controls />\n    </ReactFlow>\n  );\n}",
            "after": "    },\n    [onProjectChange, project],\n  );\n\n  /**\n   * onConnect fires when the user drags from a source handle to a target node.\n   * Creates a minimum-valid ecm:RelationAssertion (SPEC section 5.9).\n   * ecm:predicateIri is set to the placeholder \"ecm:UnassignedPredicate\" so\n   * the isEcmRelation type guard passes; the user assigns the real predicate\n   * via the Inspector dropdown (FR-U015, task 2.6 Chain B).\n   */\n  const handleConnect = useCallback(\n    (connection: Connection) => {\n      if (onProjectChange === undefined) return;\n      const newRelId = `urn:uuid:${crypto.randomUUID()}`;\n      const newRelation: Record<string, unknown> = {\n        id: newRelId,\n        type: \"ecm:RelationAssertion\",\n        \"ecm:subjectIri\": connection.source,\n        \"ecm:predicateIri\": \"ecm:UnassignedPredicate\",\n        \"ecm:objectIri\": connection.target,\n      };\n      const existingRelations = Array.isArray(project[\"ecm:relations\"])\n        ? (project[\"ecm:relations\"] as unknown[])\n        : [];\n      onProjectChange({\n        ...project,\n        \"ecm:relations\": [...existingRelations, newRelation],\n      });\n    },\n    [onProjectChange, project],\n  );\n\n  /** onEdgeClick: notify parent of the selected relation id (FR-U015/U016/U017 wiring). */\n  const handleEdgeClick = useCallback(\n    (_event: ReactMouseEvent, edge: RelationEdge) => {\n      onEdgeSelect?.(edge.id);\n    },\n    [onEdgeSelect],\n  );\n\n  return (\n    <ReactFlow\n      nodes={nodes}\n      edges={edges}\n      nodesDraggable={onProjectChange !== undefined}\n      nodesConnectable={onProjectChange !== undefined}\n      elementsSelectable={onProjectChange !== undefined}\n      fitView={nodes.length > 0}\n      onPaneClick={handlePaneClick}\n      onNodeDragStop={handleNodeDragStop}\n      onConnect={handleConnect}\n      onEdgeClick={handleEdgeClick}\n    >\n      <Background />\n      <Controls />\n    </ReactFlow>\n  );\n}",
            "scope": "moderate"
          },
          {
            "id": "C6",
            "file": "src/ui/CanvasView.tsx",
            "rationale": "Destructure onEdgeSelect in the CanvasView wrapper so it can be passed through to CanvasViewInner.",
            "before": "export function CanvasView({ project, onProjectChange }: CanvasViewProps) {",
            "after": "export function CanvasView({ project, onProjectChange, onEdgeSelect }: CanvasViewProps) {",
            "scope": "minimal"
          },
          {
            "id": "C7",
            "file": "src/ui/CanvasView.tsx",
            "rationale": "Forward onEdgeSelect from CanvasView to CanvasViewInner.",
            "before": "      <ReactFlowProvider>\n        <CanvasViewInner\n          nodes={nodes}\n          edges={edges}\n          project={project}\n          onProjectChange={onProjectChange}\n        />\n      </ReactFlowProvider>",
            "after": "      <ReactFlowProvider>\n        <CanvasViewInner\n          nodes={nodes}\n          edges={edges}\n          project={project}\n          onProjectChange={onProjectChange}\n          onEdgeSelect={onEdgeSelect}\n        />\n      </ReactFlowProvider>",
            "scope": "minimal"
          },
          {
            "id": "C8",
            "file": "src/ui/Inspector.tsx",
            "rationale": "New Inspector component (Chain A skeleton). Renders read-only relation details (subjectIri, predicateIri, objectIri) when an edge is selected; placeholder text otherwise. Chain B replaces the predicate field with a dropdown (FR-U015) and adds Reverse (FR-U016) and Delete (FR-U017) buttons with onProjectChange mutations.",
            "before": null,
            "after": "// ---------------------------------------------------------------------------\n// Domain types (local to Inspector; shared extraction is a future refactor)\n// ---------------------------------------------------------------------------\n\ninterface EcmRelation {\n  id: string;\n  type: string;\n  \"ecm:subjectIri\": string;\n  \"ecm:predicateIri\": string;\n  \"ecm:objectIri\": string;\n}\n\nfunction isEcmRelation(v: unknown): v is EcmRelation {\n  if (v === null || typeof v !== \"object\") return false;\n  const obj = v as Record<string, unknown>;\n  return (\n    typeof obj[\"id\"] === \"string\" &&\n    obj[\"type\"] === \"ecm:RelationAssertion\" &&\n    typeof obj[\"ecm:subjectIri\"] === \"string\" &&\n    typeof obj[\"ecm:objectIri\"] === \"string\" &&\n    typeof obj[\"ecm:predicateIri\"] === \"string\"\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Inspector component (SPEC section 26; FR-U015 / FR-U016 / FR-U017)\n// ---------------------------------------------------------------------------\n\ninterface InspectorProps {\n  selectedRelationId: string | null;\n  project: Record<string, unknown> | null;\n  /**\n   * Called with the updated project document on relation mutation.\n   * Used by Chain B (Reverse / Delete); accepted here so App can pass it\n   * unconditionally and the prop shape is stable across chains.\n   */\n  onProjectChange?: (updated: Record<string, unknown>) => void;\n}\n\n/**\n * Inspector panel -- right sidebar (SPEC section 26).\n *\n * Chain A (task 2.6): read-only relation details for the selected edge.\n * Chain B (task 2.6): predicate dropdown (FR-U015), Reverse (FR-U016),\n *                     Delete (FR-U017) with onProjectChange mutations.\n */\nexport function Inspector({\n  selectedRelationId,\n  project,\n}: InspectorProps) {\n  if (selectedRelationId === null || project === null) {\n    return (\n      <p className=\"gw-placeholder\" data-testid=\"gw-inspector-empty\">\n        Select a relation to inspect.\n      </p>\n    );\n  }\n\n  const rawRelations = Array.isArray(project[\"ecm:relations\"])\n    ? (project[\"ecm:relations\"] as unknown[])\n    : [];\n\n  const rel = rawRelations.find(\n    (r): r is EcmRelation => isEcmRelation(r) && r.id === selectedRelationId,\n  );\n\n  if (rel === undefined) {\n    return (\n      <p className=\"gw-placeholder\" data-testid=\"gw-inspector-empty\">\n        Select a relation to inspect.\n      </p>\n    );\n  }\n\n  return (\n    <div data-testid=\"gw-inspector-relation\">\n      <p style={{ fontWeight: 600, marginBottom: \"0.5rem\" }}>Relation</p>\n\n      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Subject\n      </p>\n      <p\n        style={{\n          fontSize: \"0.8rem\",\n          wordBreak: \"break-all\",\n          marginBottom: \"0.75rem\",\n        }}\n        data-testid=\"gw-inspector-subject\"\n      >\n        {rel[\"ecm:subjectIri\"]}\n      </p>\n\n      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Predicate\n      </p>\n      <p\n        style={{\n          fontSize: \"0.8rem\",\n          wordBreak: \"break-all\",\n          marginBottom: \"0.75rem\",\n          fontStyle:\n            rel[\"ecm:predicateIri\"] === \"ecm:UnassignedPredicate\"\n              ? \"italic\"\n              : \"normal\",\n        }}\n        data-testid=\"gw-inspector-predicate\"\n      >\n        {rel[\"ecm:predicateIri\"] === \"ecm:UnassignedPredicate\"\n          ? \"(unassigned -- select in Chain B)\"\n          : rel[\"ecm:predicateIri\"]}\n        {/* Chain B: replace with <select> of owl:ObjectProperty terms (FR-U015) */}\n      </p>\n\n      <p style={{ fontSize: \"0.75rem\", color: \"#64748b\", marginBottom: \"0.125rem\" }}>\n        Object\n      </p>\n      <p\n        style={{\n          fontSize: \"0.8rem\",\n          wordBreak: \"break-all\",\n          marginBottom: \"0.75rem\",\n        }}\n        data-testid=\"gw-inspector-object\"\n      >\n        {rel[\"ecm:objectIri\"]}\n      </p>\n\n      {/* Chain B: Reverse button (FR-U016) and Delete button (FR-U017) */}\n    </div>\n  );\n}",
            "scope": "moderate"
          },
          {
            "id": "C9",
            "file": "src/ui/App.tsx",
            "rationale": "Import Inspector component so it can be rendered in the right sidebar.",
            "before": "import { CanvasView } from \"./CanvasView.js\";\nimport { TermSidebar } from \"./TermSidebar.js\";",
            "after": "import { CanvasView } from \"./CanvasView.js\";\nimport { Inspector } from \"./Inspector.js\";\nimport { TermSidebar } from \"./TermSidebar.js\";",
            "scope": "minimal"
          },
          {
            "id": "C10",
            "file": "src/ui/App.tsx",
            "rationale": "Add selectedRelationId state so App can track which relation edge is selected and pass it to Inspector.",
            "before": "  const [project, setProject] = useState<Record<string, unknown> | null>(null);\n  const [migrationBannerText, setMigrationBannerText] = useState<string | null>(null);",
            "after": "  const [project, setProject] = useState<Record<string, unknown> | null>(null);\n  const [migrationBannerText, setMigrationBannerText] = useState<string | null>(null);\n  const [selectedRelationId, setSelectedRelationId] = useState<string | null>(null);",
            "scope": "minimal"
          },
          {
            "id": "C11",
