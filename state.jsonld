                "excerpt": "<li\n  key={term.id}\n  className=\"gw-term-item\"\n  data-testid=\"gw-term-item\"\n>\n  <span className=\"gw-term-label\">{displayLabel}</span>\n  <SourceBadge source={term[\"ecm:source\"]} />\n</li>"
              }
            ],
