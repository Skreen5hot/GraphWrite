              },
              {
                "file": "node_modules/@xyflow/react/dist/esm/types/nodes.d.ts",
                "lines": "36",
                "excerpt": "export type OnNodeDrag<NodeType extends Node = Node> = (event: ReactMouseEvent, node: NodeType, nodes: NodeType[]) => void;"
              }
            ],
            "kind": "observation"
          },
