      "@id": "urn:fnsr:task:229-recon-triple-preview",
      "agent": "reconnaissance",
      "status": "done",
      "attempts": 1,
      "outputs": {
        "findings": [
          {
            "id": "F1",
            "claim": "FR-C008 narration template is a five-slot format '{subjectLabel} ({className}) {predicateLabel} {objectLabel} ({objectClassName})', not a generic Subject-Predicate-Object string.",
            "evidence": [
              {
                "file": "src/emit/triple-narration.ts",
                "lines": "5-7",
                "excerpt": "* SPEC refs: section 7.1, FR-C008.\n *\n * Template: \"{subjectLabel} ({className}) {predicateLabel} {objectLabel} ({objectClassName})\""
              },
              {
                "file": "src/emit/triple-narration.ts",
                "lines": "45-48",
                "excerpt": "export function narrateTriple(input: NarrationInput): string {\n  const { subjectLabel, className, predicateLabel, objectLabel, objectClassName } = input;\n  return `${subjectLabel} (${className}) ${predicateLabel} ${objectLabel} (${objectClassName})`;\n}"
              },
              {
                "file": "project/SPEC.md",
                "lines": "1308",
                "excerpt": "| FR-C008 | Generate a templated triple-narration (\"Alice (Person) participates in Meeting1 (Meeting)\"). Full natural-language generation is out of scope. |"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F2",
            "claim": "`narrateTriple` requires five pre-resolved label strings via `NarrationInput`; `narrateProject` resolves all relations for a full project document but returns a flat string array with no per-relation ID.",
            "evidence": [
              {
                "file": "src/emit/triple-narration.ts",
                "lines": "25-32",
                "excerpt": "export interface NarrationInput {\n  subjectLabel:    string;\n  className:       string;\n  predicateLabel:  string;\n  objectLabel:     string;\n  objectClassName: string;\n}"
              },
              {
                "file": "src/emit/triple-narration.ts",
                "lines": "97-122",
                "excerpt": "const results: string[] = [];\n  ...\n  for (const item of relations as unknown[]) {\n    ...\n    results.push(narrateTriple({...}));\n  }\n  return results;"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F3",
            "claim": "Label resolution order in `narrateProject` is: subjectLabel = instance rdfs:label ?? instance id; className = term rdfs:label for first classIri ?? classIri ?? ''; predicateLabel = term rdfs:label ?? relation rdfs:label ?? predicateIri; objectLabel = instance rdfs:label ?? id; objectClassName = term rdfs:label for first classIri of object ?? classIri ?? ''.",
            "evidence": [
              {
                "file": "src/emit/triple-narration.ts",
