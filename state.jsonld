              }
            ],
            "kind": "gap"
          },
          {
            "id": "F9",
            "claim": "`package.json` devDependencies contains only: `@types/n3`, `@types/node`, `fast-check`, `n3`, `rimraf`, `typescript`. React, react-dom, @types/react, @types/react-dom, vite, @vitejs/plugin-react, and @playwright/test are all absent.",
            "evidence": [
              {
                "file": "package.json",
                "lines": "34-43",
                "excerpt": "\"devDependencies\": {\n  \"@types/n3\": \"^1.26.1\",\n  \"@types/node\": \"^22.0.0\",\n  \"fast-check\": \"^3.0.0\",\n  \"n3\": \"^1.21.0\",\n  \"rimraf\": \"^6.0.0\",\n  \"typescript\": \"^5.7.0\"\n}"
              }
            ],
            "kind": "gap"
          },
          {
            "id": "F10",
            "claim": "`tsconfig.json` targets ES2022 with `module: NodeNext`, `lib: [\"ES2022\"]`, and `types: [\"node\"]`, with no JSX configuration and no DOM lib. This configuration cannot compile browser-targeted React TSX files without modification.",
            "evidence": [
              {
                "file": "tsconfig.json",
                "lines": "1-20",
                "excerpt": "\"target\": \"ES2022\",\n\"module\": \"NodeNext\",\n\"moduleResolution\": \"NodeNext\",\n\"outDir\": \"./dist\",\n\"rootDir\": \"./src\",\n\"lib\": [\"ES2022\"],\n\"types\": [\"node\"]\n... \"include\": [\"src/**/*\"]"
              }
            ],
            "kind": "observation"
          },
          {
            "id": "F11",
            "claim": "`tsconfig.test.json` extends `tsconfig.json` and adds `tests/**/*`, `scripts/**/*`, and `examples/**/*` to `include`; its `rootDir: \".\"` and `outDir: \"./dist-tests\"` are distinct from the main build. A browser-targeted tsconfig for the UI build would need to be a parallel config (not extending the Node-targeted base) to avoid NodeNext/DOM conflicts.",
