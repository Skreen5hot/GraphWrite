              }
            ],
            "kind": "observation"
          },
          {
            "id": "F3",
            "claim": "stableStringify does not append a terminating newline character; the CLI entry point adds it externally (`+ \"\\n\"`), meaning the serializer function itself does not satisfy \u00c2\u00a75.3 rule 6 as a standalone unit.",
            "evidence": [
              {
                "file": "src/kernel/canonicalize.ts",
                "lines": "50-55",
                "excerpt": "export function stableStringify(value: unknown, pretty: boolean = false): string {\n  const canonical = canonicalize(value);\n  return pretty\n    ? JSON.stringify(canonical, null, 2)\n    : JSON.stringify(canonical);\n}"
              },
              {
                "file": "src/kernel/index.ts",
                "lines": "34",
                "excerpt": "process.stdout.write(stableStringify(output, true) + \"\\n\");"
