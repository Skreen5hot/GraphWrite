      "outputs": {
        "changes": [
          {
            "id": "C1",
            "file": "package.json",
            "rationale": "Add fast-check as devDependency. Inserted alphabetically between @types/node and n3. fast-check v3 bundles its own TypeScript types; no @types/fast-check needed. Operator runs 'npm i --save-dev fast-check' post-applier per gap-12 pattern.",
            "before": "  \"devDependencies\": {\n    \"@types/n3\": \"^1.26.1\",\n    \"@types/node\": \"^22.0.0\",\n    \"n3\": \"^1.21.0\",\n    \"rimraf\": \"^6.0.0\",\n    \"typescript\": \"^5.7.0\"\n  },",
            "after": "  \"devDependencies\": {\n    \"@types/n3\": \"^1.26.1\",\n    \"@types/node\": \"^22.0.0\",\n    \"fast-check\": \"^3.0.0\",\n    \"n3\": \"^1.21.0\",\n    \"rimraf\": \"^6.0.0\",\n    \"typescript\": \"^5.7.0\"\n  },",
            "scope": "minimal"
