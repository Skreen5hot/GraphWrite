{
  "name": "json-ld-deterministic-service-template",
  "version": "0.1.0",
  "description": "A minimal template for building deterministic JSON-LD transformation services",
  "type": "module",
  "main": "dist/kernel/index.js",
  "types": "dist/kernel/index.d.ts",
  "bin": {
    "graphwrite": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:tests": "tsc -p tsconfig.test.json",
    "build:ui": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "start": "node dist/kernel/index.js",
    "test": "npm run build:tests && node dist-tests/tests/run-tests.js",
    "test:e2e": "playwright test",
    "test:purity": "npm run build:tests && node dist-tests/scripts/ensure-kernel-purity.js",
    "typecheck:ui": "tsc --noEmit -p tsconfig.ui.json",
    "clean": "rimraf dist dist-tests"
  },
  "keywords": [
    "json-ld",
    "deterministic",
    "edge-computing",
    "architecture",
    "offline-first",
    "template"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "homepage": "",
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/n3": "^1.26.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@xyflow/react": "^12.0.0",
    "fast-check": "^3.0.0",
    "n3": "^1.21.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
